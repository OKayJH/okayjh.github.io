---
// src/components/TableOfContents.astro
import type { MarkdownHeading } from 'astro';

export interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Filter out h1 (usually the title) and keep h2-h4 for the TOC
const tocHeadings = headings.filter((h) => h.depth > 1 && h.depth <= 4);
---

{tocHeadings.length > 0 && (
  <div class="toc-fixed-container" id="toc-container">
    <button class="toc-toggle-btn" id="toc-toggle-btn" title="收起/展开目录">
      <span class="material-icons-round" id="toc-toggle-icon">menu_open</span>
    </button>
    <nav class="article-toc" aria-label="Table of Contents">
      <div class="toc-header">
        <span class="material-icons-round">list</span>
        <span class="toc-title">目录</span>
      </div>
      <ul class="toc-list" id="toc-list">
        {tocHeadings.map((heading) => (
          <li class={`toc-item depth-${heading.depth}`}>
            <a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<script>
  function setupTocToggle() {
    const btn = document.getElementById('toc-toggle-btn');
    const container = document.getElementById('toc-container');
    const icon = document.getElementById('toc-toggle-icon');
    if (!btn || !container || !icon) return;

    // Check localStorage for preferred state
    const isCollapsed = localStorage.getItem('okay_toc_collapsed') === 'true';
    if (isCollapsed) {
      container.classList.add('collapsed');
      icon.textContent = 'menu';
    }

    // Ensure only one listener is attached (important for Astro view transitions)
    btn.removeEventListener('click', btn._toggleHandler);
    btn._toggleHandler = () => {
      container.classList.toggle('collapsed');
      const collapsed = container.classList.contains('collapsed');
      localStorage.setItem('okay_toc_collapsed', collapsed ? 'true' : 'false');
      icon.textContent = collapsed ? 'menu' : 'menu_open';
    };
    btn.addEventListener('click', btn._toggleHandler);
  }

  function setupScrollSpy() {
    const headings = Array.from(document.querySelectorAll('.markdown-body h2[id], .markdown-body h3[id], .markdown-body h4[id]'));
    if (headings.length === 0) return;

    function onScroll() {
      // Find the heading that is closest to the top of the screen (or currently past it)
      let activeHeading = headings[0];
      for (const heading of headings) {
        // Adjust the offset threshold so it becomes active just as it enters the readable area
        if (heading.getBoundingClientRect().top < 200) {
          activeHeading = heading;
        } else {
          break; // Since headings are in order, we can stop checking once we find one below the threshold
        }
      }

      if (!activeHeading) return;
      const id = activeHeading.getAttribute('id');
      
      const tocLinks = document.querySelectorAll('.toc-link');
      let currentActiveLink = null;
      
      tocLinks.forEach((link) => {
        if (link.getAttribute('data-slug') === id) {
          link.classList.add('active');
          currentActiveLink = link;
        } else {
          link.classList.remove('active');
        }
      });

      // Optionally animate the TOC container's scroll position without hijacking the main window
      if (currentActiveLink) {
        const tocContainer = document.querySelector('.article-toc');
        if (tocContainer) {
          const linkTop = currentActiveLink.offsetTop;
          const containerHeight = tocContainer.clientHeight;
          // Smoothly scroll the container so the link is visible in the middle
          tocContainer.scrollTo({
            top: linkTop - containerHeight / 2 + 20, 
            behavior: 'smooth'
          });
        }
      }
    }

    // Attach scroll listener, remove previous to prevent duplicates on view transition
    if (window._tocScrollListener) {
      window.removeEventListener('scroll', window._tocScrollListener);
    }
    window._tocScrollListener = onScroll;
    window.addEventListener('scroll', window._tocScrollListener, { passive: true });
    
    // Trigger once on load wrapper
    onScroll();
  }

  function initToc() {
    // Small delay ensures DOM is fully painted and rects are accurate
    setTimeout(() => {
      setupScrollSpy();
      setupTocToggle();
    }, 100);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initToc);
  } else {
    initToc();
  }
  document.addEventListener('astro:page-load', initToc);
</script>
