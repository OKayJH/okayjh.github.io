									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
								</div>
							</div>
						</div>
						<div class="dev-char char-diamond" data-depth="0.8">
							<div class="dev-char-motion">
								<div class="dev-char-shape">
									<div class="dev-char-back"></div>
									<div class="dev-face face-playful">
										<div class="dev-cheeks">
											<div class="dev-cheek"></div>
											<div class="dev-cheek"></div>
										</div>
										<div class="dev-eyes">
											<div class="dev-eye"><div class="dev-pupil"></div></div>
											<div class="dev-eye"><div class="dev-pupil"></div></div>
										</div>
										<div class="dev-mouth mouth-smile"></div>
									</div>
								</div>
								<div class="dev-legs">
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
								</div>
							</div>
						</div>
						<div class="dev-char char-cloud" data-depth="1.05">
							<div class="dev-char-motion">
								<div class="dev-char-shape">
									<div class="dev-char-back"></div>
									<div class="dev-face face-sad">
										<div class="dev-cheeks">
											<div class="dev-cheek"></div>
											<div class="dev-cheek"></div>
										</div>
										<div class="dev-eyes">
											<div class="dev-eye"><div class="dev-pupil"></div></div>
											<div class="dev-eye"><div class="dev-pupil"></div></div>
										</div>
										<div class="dev-mouth mouth-frown"></div>
									</div>
								</div>
								<div class="dev-legs">
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
								</div>
							</div>
						</div>
						<div class="dev-char char-triangle" data-depth="1.1">
							<div class="dev-char-motion">
								<div class="dev-char-shape">
									<div class="dev-char-back"></div>
									<div class="dev-face">
										<div class="dev-cheeks">
											<div class="dev-cheek"></div>
											<div class="dev-cheek"></div>
										</div>
										<div class="dev-eyes">
											<div class="dev-eye"><div class="dev-pupil"></div></div>
											<div class="dev-eye"><div class="dev-pupil"></div></div>
										</div>
										<div class="dev-mouth mouth-o"></div>
									</div>
								</div>
								<div class="dev-legs">
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
								</div>
							</div>
						</div>
						<div class="dev-char char-circle" data-depth="1.14">
							<div class="dev-char-motion">
								<div class="dev-char-shape">
									<div class="dev-char-back"></div>
									<div class="dev-face">
										<div class="dev-cheeks">
											<div class="dev-cheek"></div>
											<div class="dev-cheek"></div>
										</div>
										<div class="dev-eyes">
											<div class="dev-eye"><div class="dev-pupil"></div></div>
											<div class="dev-eye"><div class="dev-pupil"></div></div>
										</div>
										<div class="dev-mouth mouth-smile-wide"></div>
									</div>
								</div>
								<div class="dev-legs">
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
									<div class="dev-leg"><div class="dev-shin"></div><div class="dev-shoe"></div></div>
								</div>
							</div>
						</div>
					</div>
					<div class="scene-stage"></div>
				</div>
				<div class="dev-login-form">
					<h2 id="dev-login-title">开发者模式登录</h2>
					<form id="dev-auth-form" novalidate>
						<div class="dev-input-group">
							<label for="dev-user">用户名</label>
							<div class="dev-input-shell">
								<span class="material-icons-round dev-input-icon" aria-hidden="true">person</span>
								<input type="text" id="dev-user" placeholder="输入开发者用户名" autocomplete="username" spellcheck="false">
							</div>
						</div>
						<div class="dev-input-group">
							<label for="dev-pwd">密码</label>
							<div class="dev-input-shell">
								<span class="material-icons-round dev-input-icon" aria-hidden="true">lock</span>
								<input type="password" id="dev-pwd" placeholder="输入密码" autocomplete="current-password">
								<button type="button" class="dev-password-toggle" id="dev-password-toggle" aria-label="显示密码" aria-pressed="false">
									<span class="material-icons-round" aria-hidden="true">visibility_off</span>
								</button>
							</div>
						</div>
						<p id="dev-error-msg" class="dev-status-message" role="alert" aria-live="polite" hidden></p>
						<div class="dev-form-actions">
							<button type="button" class="dev-btn dev-btn-cancel">取消</button>
							<button type="submit" class="dev-btn dev-btn-login">进入开发者模式</button>
						</div>
					</form>
				</div>
			</div>
		</div>
		<script is:inline>
			(() => {
				if (window._okayDevModalCleanup) {
					window._okayDevModalCleanup();
				}

				const triggerArea = document.getElementById('dev-trigger-area');
				const authModal = document.getElementById('dev-auth-modal');
				const loginCard = document.getElementById('dev-login-card');
				const authForm = document.getElementById('dev-auth-form');
				if (!triggerArea || !authModal || !loginCard || !authForm) return;

				const cancelBtn = authModal.querySelector('.dev-btn-cancel');
				const loginBtn = authModal.querySelector('.dev-btn-login');
				const togglePwdBtn = document.getElementById('dev-password-toggle');
				const userInp = document.getElementById('dev-user');
				const passInp = document.getElementById('dev-pwd');
				const errorMsg = document.getElementById('dev-error-msg');
				const userShell = userInp ? userInp.closest('.dev-input-shell') : null;
				const passShell = passInp ? passInp.closest('.dev-input-shell') : null;
				const charElements = Array.from(authModal.querySelectorAll('.dev-char'));
				const charMotions = Array.from(authModal.querySelectorAll('.dev-char-motion'));
				const pupils = Array.from(authModal.querySelectorAll('.dev-pupil'));
				const focusableSelector = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
				const interactionClasses = ['interaction-a', 'interaction-b', 'interaction-c'];
				const closeDelayMs = 280;
				const successDelayMs = 720;
				const settleDelayMs = 1800;
				
				let clickCount = 0;
				let clickTimer = null;
				let isTracking = false;
				let hideTimer = null;
				let successTimer = null;
				let errorTimer = null;
				let focusTimer = null;
				let settleTimer = null;
				let interactionTimer = null;
				let interactionIndex = -1;
				let lastFocusedElement = null;

				if (!cancelBtn || !loginBtn || !togglePwdBtn || !userInp || !passInp || !errorMsg) return;

				const isDevMode = localStorage.getItem('okay_dev_mode') === 'true';
				if (isDevMode) {
					document.body.classList.add('dev-mode-active');
				}

				const clearTimer = (timerRef) => {
					if (timerRef) {
						window.clearTimeout(timerRef);
					}
					return null;
				};

				const resetPupils = () => {
					pupils.forEach(pupil => {
						pupil.style.setProperty('--look-x', '0px');
						pupil.style.setProperty('--look-y', '0px');
					});
				};

				const setStaticGaze = (lookX, lookY = 0) => {
					pupils.forEach((pupil, index) => {
						const wobble = index % 2 === 0 ? 0.16 : -0.16;
						pupil.style.setProperty('--look-x', `${(lookX + wobble).toFixed(2)}px`);
						pupil.style.setProperty('--look-y', `${lookY.toFixed(2)}px`);
					});
				};

				const resetCharacterMotion = () => {
					charMotions.forEach((motion) => {
						motion.style.setProperty('--body-x', '0px');
						motion.style.setProperty('--body-y', '0px');
						motion.style.setProperty('--body-rotate', '0deg');
						motion.style.setProperty('--face-x', '0px');
						motion.style.setProperty('--face-y', '0px');
					});
				};

				const clearInteractionStates = () => {
					authModal.classList.remove(...interactionClasses);
				};

				const stopCharacterInteractions = () => {
					interactionTimer = clearTimer(interactionTimer);
					interactionIndex = -1;
					clearInteractionStates();
				};

				const startCharacterInteractions = () => {
					if (!authModal.classList.contains('scene-settled')) return;
					if (authModal.classList.contains('user-focused')) return;
					if (authModal.classList.contains('pwd-focused') && !authModal.classList.contains('show-password')) return;

					stopCharacterInteractions();
					interactionIndex = 0;
					authModal.classList.add(interactionClasses[interactionIndex]);
					interactionTimer = window.setInterval(() => {
						interactionIndex = (interactionIndex + 1) % interactionClasses.length;
						clearInteractionStates();
						authModal.classList.add(interactionClasses[interactionIndex]);
					}, 2100);
				};

				const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

				const moveScene = (clientX, clientY, options = {}) => {
					const maxDistance = options.pupilMaxDistance ?? 3.5;
					const bodyScale = options.bodyScale ?? 1;

					pupils.forEach((pupil) => {
						const eye = pupil.parentElement;
						if (!eye) return;
						const rect = eye.getBoundingClientRect();
						const eyeX = rect.left + rect.width / 2;
						const eyeY = rect.top + rect.height / 2;

						const deltaX = clientX - eyeX;
						const deltaY = clientY - eyeY;
						const angle = Math.atan2(deltaY, deltaX);
						const distance = Math.min(maxDistance, Math.hypot(deltaX, deltaY) / 18);
						const moveX = Math.cos(angle) * distance;
						const moveY = Math.sin(angle) * distance;

						pupil.style.setProperty('--look-x', `${moveX.toFixed(2)}px`);
						pupil.style.setProperty('--look-y', `${moveY.toFixed(2)}px`);
					});

					charMotions.forEach((motion, index) => {
						const host = charElements[index];
						const depth = host ? Number(host.dataset.depth || '1') : 1;
						const rect = motion.getBoundingClientRect();
						const centerX = rect.left + rect.width / 2;
						const centerY = rect.top + rect.height * 0.42;
						const deltaX = clientX - centerX;
						const deltaY = clientY - centerY;
						const distance = Math.hypot(deltaX, deltaY);
						const strength = 0.24 + (1 - Math.min(distance, 320) / 320) * 0.76;

						const bodyX = clamp(deltaX * 0.045 * depth * strength * bodyScale, -14 * depth, 14 * depth);
						const bodyY = clamp(deltaY * 0.018 * depth * strength * bodyScale, -7 * depth, 9 * depth);
						const bodyRotate = clamp(deltaX * 0.03 * depth * strength * bodyScale, -10 * depth, 10 * depth);

						motion.style.setProperty('--body-x', `${bodyX.toFixed(2)}px`);
						motion.style.setProperty('--body-y', `${bodyY.toFixed(2)}px`);
						motion.style.setProperty('--body-rotate', `${bodyRotate.toFixed(2)}deg`);
						motion.style.setProperty('--face-x', `${(bodyX * 0.48).toFixed(2)}px`);
						motion.style.setProperty('--face-y', `${(bodyY * 0.28).toFixed(2)}px`);
					});
				};

				const lookAtInput = (input) => {
					const rect = input.getBoundingClientRect();
					const anchorX = rect.left + rect.width * Math.min(0.72, 0.35 + input.value.length * 0.04);
					const anchorY = rect.top + rect.height / 2;
					moveScene(anchorX, anchorY, { pupilMaxDistance: 2.7, bodyScale: 0.72 });
				};

				const activateUserFocus = () => {
					authModal.classList.add('user-focused');
					authModal.classList.remove('pwd-focused');
					stopCharacterInteractions();
					if (isTracking) {
						lookAtInput(userInp);
					}
				};

				const releaseUserFocus = () => {
					if (authModal.classList.contains('pwd-focused') || document.activeElement === passInp) return;
					authModal.classList.remove('user-focused');
					resetCharacterMotion();
					resetPupils();
					if (authModal.classList.contains('scene-settled')) {
						startCharacterInteractions();
					}
				};

				const activatePasswordFocus = () => {
					authModal.classList.remove('user-focused');
					authModal.classList.add('pwd-focused');
					stopCharacterInteractions();
					resetCharacterMotion();
					setStaticGaze(-1.75, -0.1);
				};

				const releasePasswordFocus = () => {
					if (authModal.classList.contains('user-focused') || document.activeElement === userInp) return;
					if (authModal.classList.contains('show-password')) return;
					authModal.classList.remove('pwd-focused');
					resetCharacterMotion();
					resetPupils();
					if (authModal.classList.contains('scene-settled')) {
						startCharacterInteractions();
					}
				};

				const focusables = () => Array.from(authModal.querySelectorAll(focusableSelector)).filter((element) => {
					return !element.hasAttribute('disabled') && element.offsetParent !== null;
				});

				const resetFormState = () => {
					authModal.classList.remove('login-error', 'login-success', 'user-focused', 'pwd-focused', 'show-password', 'scene-settled');
					clearInteractionStates();
					errorMsg.hidden = true;
					errorMsg.textContent = '';
					userInp.disabled = false;
					passInp.disabled = false;
					loginBtn.disabled = false;
					cancelBtn.disabled = false;
					togglePwdBtn.disabled = false;
					passInp.type = 'password';
					togglePwdBtn.setAttribute('aria-pressed', 'false');
					const toggleIcon = togglePwdBtn.querySelector('.material-icons-round');
					if (toggleIcon) toggleIcon.textContent = 'visibility_off';
					togglePwdBtn.setAttribute('aria-label', '显示密码');
				};

				const clearError = () => {
					errorTimer = clearTimer(errorTimer);
					authModal.classList.remove('login-error');
					errorMsg.hidden = true;
					errorMsg.textContent = '';
				};

				const showError = (message) => {
					successTimer = clearTimer(successTimer);
					errorTimer = clearTimer(errorTimer);
					authModal.classList.remove('login-success');
					authModal.classList.add('login-error');
					errorMsg.textContent = message;
					errorMsg.hidden = false;
					errorTimer = window.setTimeout(() => {
						authModal.classList.remove('login-error');
					}, 720);
				};

				const setPasswordVisibility = (visible) => {
					passInp.type = visible ? 'text' : 'password';
					authModal.classList.toggle('show-password', visible);
					togglePwdBtn.setAttribute('aria-pressed', String(visible));
					togglePwdBtn.setAttribute('aria-label', visible ? '隐藏密码' : '显示密码');
					const toggleIcon = togglePwdBtn.querySelector('.material-icons-round');
					if (toggleIcon) {
						toggleIcon.textContent = visible ? 'visibility' : 'visibility_off';
					}
					if (!visible && document.activeElement !== passInp) {
						authModal.classList.remove('pwd-focused');
					}
				};

				const closeModal = (restoreFocus = true) => {
					hideTimer = clearTimer(hideTimer);
					successTimer = clearTimer(successTimer);
					errorTimer = clearTimer(errorTimer);
					focusTimer = clearTimer(focusTimer);
					settleTimer = clearTimer(settleTimer);
					stopCharacterInteractions();
					authModal.classList.remove('visible', 'login-error', 'login-success', 'pwd-focused', 'show-password', 'scene-settled');
					authModal.setAttribute('aria-hidden', 'true');
					document.body.classList.remove('dev-modal-open');
					isTracking = false;

					hideTimer = window.setTimeout(() => {
						authModal.style.display = 'none';
						setPasswordVisibility(false);
						authForm.reset();
						resetFormState();
						resetPupils();
						resetCharacterMotion();
						if (restoreFocus && lastFocusedElement && typeof lastFocusedElement.focus === 'function') {
							lastFocusedElement.focus();
						}
					}, closeDelayMs);
				};

				const openModal = () => {
					if (document.body.classList.contains('dev-mode-active')) return;

					hideTimer = clearTimer(hideTimer);
					successTimer = clearTimer(successTimer);
					errorTimer = clearTimer(errorTimer);
					focusTimer = clearTimer(focusTimer);
					settleTimer = clearTimer(settleTimer);
					stopCharacterInteractions();
					lastFocusedElement = document.activeElement;
					authForm.reset();
					resetFormState();
					resetPupils();
					resetCharacterMotion();

					authModal.style.display = 'flex';
					authModal.setAttribute('aria-hidden', 'false');
					document.body.classList.add('dev-modal-open');
					isTracking = true;

					if (window.getSelection) {
						window.getSelection().removeAllRanges();
					}

					requestAnimationFrame(() => {
						requestAnimationFrame(() => {
							authModal.classList.add('visible');
						});
					});

					focusTimer = window.setTimeout(() => {
						userInp.focus();
						lookAtInput(userInp);
					}, 430);
					settleTimer = window.setTimeout(() => {
						authModal.classList.add('scene-settled');
						startCharacterInteractions();
					}, settleDelayMs);
				};

				const attemptLogin = () => {
					const username = userInp.value.trim();
					const password = passInp.value.trim();

					if (!username || !password) {
						showError('请输入用户名和密码。');
						if (!username) {
							userInp.focus();
						} else {
							passInp.focus();
						}
						return;
					}

					if (username === 'OKay' && password === 'Jhh20040314') {
						clearError();
						authModal.classList.add('login-success');
						userInp.disabled = true;
						passInp.disabled = true;
						loginBtn.disabled = true;
						cancelBtn.disabled = true;
						togglePwdBtn.disabled = true;
						isTracking = false;

						successTimer = window.setTimeout(() => {
							localStorage.setItem('okay_dev_mode', 'true');
							document.body.classList.add('dev-mode-active');
							closeModal(false);
							window.dispatchEvent(new Event('dev-mode-changed'));
						}, successDelayMs);
						return;
					}

					showError('用户名或密码错误，请重试。');
					passInp.focus();
					passInp.select();
				};

				const handleMouseMove = (event) => {
					if (!isTracking) return;
					if (authModal.classList.contains('user-focused')) {
						lookAtInput(userInp);
						return;
					}
					if (authModal.classList.contains('pwd-focused') && !authModal.classList.contains('show-password')) return;
					moveScene(event.clientX, event.clientY);
				};

				const handleKeyDown = (event) => {
					if (authModal.style.display === 'none') return;

					if (event.key === 'Escape') {
						event.preventDefault();
						closeModal();
						return;
					}

					if (event.key !== 'Tab') return;

					const items = focusables();
					if (items.length === 0) return;

					const first = items[0];
					const last = items[items.length - 1];

					if (event.shiftKey && document.activeElement === first) {
						event.preventDefault();
						last.focus();
					} else if (!event.shiftKey && document.activeElement === last) {
						event.preventDefault();
						first.focus();
					}
				};

				document.addEventListener('mousemove', handleMouseMove, { passive: true });
				document.addEventListener('keydown', handleKeyDown);

				userInp.addEventListener('focus', activateUserFocus);
				userInp.addEventListener('blur', () => {
					window.setTimeout(() => {
						if (document.activeElement !== userInp) {
							releaseUserFocus();
						}
					}, 0);
				});
				userInp.addEventListener('input', () => {
					clearError();
					if (isTracking) {
						lookAtInput(userInp);
					}
				});
				passInp.addEventListener('focus', activatePasswordFocus);
				passInp.addEventListener('blur', () => {
					window.setTimeout(() => {
						if (document.activeElement !== passInp) {
							releasePasswordFocus();
						}
					}, 0);
				});
				passInp.addEventListener('input', clearError);
				togglePwdBtn.addEventListener('click', () => {
					const shouldShow = passInp.type === 'password';
					setPasswordVisibility(shouldShow);
					passInp.focus();
					if (shouldShow) {
						lookAtInput(passInp);
					} else {
						setStaticGaze(-1.75, -0.1);
					}
				});
				if (userShell) {
					userShell.addEventListener('mouseenter', () => {
						if (authModal.style.display === 'none' || authModal.classList.contains('pwd-focused')) return;
						activateUserFocus();
					});
					userShell.addEventListener('mouseleave', () => {
						if (document.activeElement !== userInp) {
							releaseUserFocus();
						}
					});
				}
				if (passShell) {
					passShell.addEventListener('mouseenter', () => {
						if (authModal.style.display === 'none' || document.activeElement === passInp) return;
						authModal.classList.remove('user-focused');
					});
				}

				if (triggerArea) {
					triggerArea.addEventListener('click', () => {
						if (!['localhost', '127.0.0.1'].includes(window.location.hostname)) return;
						clickCount++;
						if (clickTimer) clearTimeout(clickTimer);
						
						if (clickCount >= 5) {
							clickCount = 0;
							openModal();
						} else {
							clickTimer = setTimeout(() => {
								clickCount = 0;
							}, 1000);
						}
					});
				}

				authModal.addEventListener('mousedown', (event) => {
					if (event.target === authModal) {
						closeModal();
					}
				});

				cancelBtn.addEventListener('click', () => closeModal());
				authForm.addEventListener('submit', (event) => {
					event.preventDefault();
					attemptLogin();
				});

				window._okayDevModalCleanup = () => {
					document.removeEventListener('mousemove', handleMouseMove);
					document.removeEventListener('keydown', handleKeyDown);
					clickTimer = clearTimer(clickTimer);
					hideTimer = clearTimer(hideTimer);
					successTimer = clearTimer(successTimer);
					errorTimer = clearTimer(errorTimer);
					focusTimer = clearTimer(focusTimer);
					settleTimer = clearTimer(settleTimer);
					interactionTimer = clearTimer(interactionTimer);
					document.body.classList.remove('dev-modal-open');
				};
			})();
		</script>
	</body>
</html>
