---
// src/pages/search.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

// 计算出精简版的文章索引供前端搜索使用
const searchIndex = posts.map(post => ({
  title: post.data.title,
  slug: post.slug,
  description: post.data.description || '',
  tags: post.data.tags,
  date: post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
}));
---

<Layout title="搜索 | OKay's Blog">
  <div class="search-page">
    <div class="search-header">
      <div class="search-box">
        <svg class="search-icon" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
        </svg>
        <input 
          type="text" 
          id="search-input" 
          placeholder="搜索博客文章..." 
          autocomplete="off"
          autofocus
        />
        <button id="clear-btn" class="clear-icon hidden" aria-label="Clear search">
          <svg focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path>
          </svg>
        </button>
      </div>
      <div id="search-stats" class="stats"></div>
    </div>

    <div id="search-results" class="results-container">
      <!-- 结果由 JS 渲染 -->
    </div>
  </div>

  <script define:vars={{ searchIndex }}>
    // 注入后端生成的数据到客户端
    window.siteSearchIndex = searchIndex;
  </script>

  <script>
    const input = document.getElementById('search-input') as HTMLInputElement;
    const clearBtn = document.getElementById('clear-btn');
    const resultsContainer = document.getElementById('search-results');
    const statsContainer = document.getElementById('search-stats');
    
    // 初始化 URL 参数
    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get('q');

    function performSearch(query: string) {
      if (!query.trim() || !window.siteSearchIndex) {
        if (resultsContainer) resultsContainer.innerHTML = '';
        if (statsContainer) statsContainer.innerHTML = '';
        clearBtn?.classList.add('hidden');
        return;
      }

      clearBtn?.classList.remove('hidden');
      
      const lowerQuery = query.toLowerCase();
      const results = window.siteSearchIndex.filter((post: any) => {
        return post.title.toLowerCase().includes(lowerQuery) || 
               post.description.toLowerCase().includes(lowerQuery) ||
               post.tags.some((tag: string) => tag.toLowerCase().includes(lowerQuery));
      });

      if (statsContainer) {
        statsContainer.innerHTML = `找到约 ${results.length} 条结果`;
      }

      if (resultsContainer) {
        if (results.length === 0) {
          resultsContainer.innerHTML = `
            <div class="no-results">
              <p>找不到和您查询的 “<strong>${query}</strong>” 相符的内容或信息。</p>
              <ul>
                <li>请检查输入字词有无错误。</li>
                <li>请尝试其他查询词。</li>
                <li>请改用较常见的字词。</li>
              </ul>
            </div>
          `;
          return;
        }

        resultsContainer.innerHTML = results.map((post: any) => `
          <div class="search-result">
            <a href="/blog/${post.slug}" class="result-title">${post.title}</a>
            <div class="result-url">okayblog.me/blog/${post.slug}</div>
            <div class="result-meta">
              <span class="date">${post.date}</span>
              ${post.tags.map((tag: string) => `<span class="tag-badge">${tag}</span>`).join('')}
            </div>
            <p class="result-desc">${highlightMatch(post.description || post.title, query)}</p>
          </div>
        `).join('');
      }
    }

    function highlightMatch(text: string, query: string) {
      if (!text || !query) return text;
      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(regex, '<em>$1</em>');
    }

    if (input) {
      input.addEventListener('input', (e) => {
        const value = (e.target as HTMLInputElement).value;
        const newUrl = new URL(window.location.href);
        if (value) {
          newUrl.searchParams.set('q', value);
        } else {
          newUrl.searchParams.delete('q');
        }
        window.history.replaceState({}, '', newUrl);
        performSearch(value);
      });

      if (initialQuery) {
        input.value = initialQuery;
        performSearch(initialQuery);
      }
    }

    if (clearBtn && input) {
      clearBtn.addEventListener('click', () => {
        input.value = '';
        input.focus();
        input.dispatchEvent(new Event('input'));
      });
    }
    
    // 支持 view transitions
    document.addEventListener('astro:page-load', () => {
      // 重新绑定事件
    });
  </script>
</Layout>

<style>
  .search-page {
    width: min(650px, calc(100% - (var(--page-gutter) * 2)));
    margin: 0 auto;
    padding-top: 88px;
    animation: fadeIn 0.4s ease-out;
  }

  .search-header {
    margin-bottom: 2rem;
  }

  .search-box {
    display: flex;
    align-items: center;
    width: 100%;
    min-height: 44px;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 22px;
    padding: 0 16px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .search-box:focus-within {
    box-shadow: 0 1px 6px rgba(32, 33, 36, 0.28);
    border-color: rgba(223, 225, 229, 0);
  }

  :global(.dark) .search-box:focus-within {
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
  }

  .search-icon {
    fill: var(--text-muted);
    width: 20px;
    height: 20px;
    margin-right: 12px;
  }

  input {
    flex: 1;
    height: 100%;
    border: none;
    background: transparent;
    color: var(--text-color);
    font-size: 16px;
    outline: none;
  }

  .clear-icon {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  .clear-icon svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .hidden {
    display: none !important;
  }

  .stats {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 1rem;
  }

  /* 搜索结果样式 */
  .results-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  :global(.search-result) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  :global(.result-title) {
    font-size: 1.25rem;
    color: var(--link-color);
    text-decoration: none;
    line-height: 1.3;
  }

  :global(.result-title:hover) {
    text-decoration: underline;
  }

  :global(.result-url) {
    font-size: 0.875rem;
    color: var(--text-color);
  }

  :global(.result-meta) {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8rem;
    margin-bottom: 0.2rem;
  }

  :global(.date) {
    color: var(--text-muted);
  }

  :global(.tag-badge) {
    background-color: var(--border-color);
    color: var(--text-color);
    padding: 0 6px;
    border-radius: 4px;
    font-size: 0.75rem;
  }

  :global(.result-desc) {
    font-size: 0.9rem;
    color: var(--text-color);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.result-desc em) {
    font-style: normal;
    font-weight: bold;
    color: var(--text-color);
    background-color: rgba(255, 255, 0, 0.2);
  }

  :global(.no-results) {
    color: var(--text-color);
  }

  :global(.no-results p) {
    margin-bottom: 1rem;
  }

  :global(.no-results ul) {
    padding-left: 2rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .search-page {
      padding-top: 76px;
    }

    .search-header {
      margin-bottom: 1.5rem;
    }

    :global(.result-title) {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 480px) {
    .search-page {
      padding-top: 72px;
    }

    .search-box {
      padding: 0 12px;
    }

    .stats {
      font-size: 0.8rem;
    }

    .results-container {
      gap: 1.5rem;
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
