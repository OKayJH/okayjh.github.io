    else if (view === 'chart') { tabChart.classList.add('active'); terminalPanel.style.display = 'none'; chartPanel.style.display = 'flex'; }
    else { tabSplit.classList.add('active'); viewsContainer.classList.add('split-view'); terminalPanel.style.display = 'flex'; chartPanel.style.display = 'flex'; }
    setTimeout(function () {
        sessions.forEach(function (s) {
            try { if (s.fitAddon) s.fitAddon.fit(); } catch (e) { }
        });
        if (chart) chart.resize();
