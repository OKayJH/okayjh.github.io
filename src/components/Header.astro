---
// src/components/Header.astro
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
});

const headerSearchIndex = posts.map((post) => ({
    title: post.data.title,
    slug: post.slug,
    url: `/blog/${post.slug}`,
    description: post.data.description || '',
    tags: Array.isArray(post.data.tags) ? post.data.tags : [],
    timestamp: new Date(post.data.date).getTime()
}));
---

<nav class="navbar" id="navbar">
    <div class="nav-inner">
        <a href="/" class="nav-logo">
            <span class="logo-icon material-icons-round">memory</span>
            <span class="logo-text">OKay<span class="logo-accent">.dev</span></span>
        </a>
        <div class="nav-center">
            <div class="search-bar" id="search-bar">
                <span class="material-icons-round search-icon">search</span>
                <input type="text" id="search-input" placeholder="搜索文章、标签..." autocomplete="off">
                <div class="search-results" id="search-results"></div>
            </div>
        </div>
        <div class="nav-right" style="gap: 12px; align-items: center;">
            <a href="/serial" class="nav-works-btn" title="串口调试" style="display: flex; align-items: center; gap: 4px; color: var(--text-secondary); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s;">
                <span class="material-icons-round" style="font-size: 18px;">terminal</span>
                <span class="nav-works-text">调试</span>
            </a>
            <a href="/works" class="nav-works-btn" title="3D 展厅" style="display: flex; align-items: center; gap: 4px; color: var(--text-secondary); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s;">
                <span class="material-icons-round" style="font-size: 18px;">view_in_ar</span>
                <span class="nav-works-text">展厅</span>
            </a>
            <a href="/editor" class="nav-create-btn" id="nav-create-btn" title="发布新文章" data-astro-reload>
                <span class="material-icons-round" style="font-size: 15px;">add</span>
                创作
            </a>
            <button class="nav-exit-dev-btn" id="nav-exit-dev-btn" title="退出开发者模式">
                退出
            </button>
            <button class="theme-toggle" id="theme-toggle" title="切换主题">
                <span class="material-icons-round" id="theme-icon">dark_mode</span>
            </button>
            <a href="/#about" class="nav-avatar-link">
                <!-- Using the downloaded avatar image -->
                <img src="/avatar.jpg" alt="OKay" class="nav-avatar">
            </a>
        </div>
    </div>
</nav>

<style>
    .nav-create-btn {
        display: none; /* hidden by default */
        align-items: center;
        gap: 4px;
        background: var(--accent);
        color: #fff;
        padding: 5px 12px;
        border-radius: 16px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s, transform 0.1s;
        box-shadow: 0 2px 6px rgba(0, 122, 204, 0.3);
        white-space: nowrap;
    }
    .nav-create-btn:hover {
        background: #0098ff;
        transform: translateY(-1px);
    }
    .nav-exit-dev-btn {
        display: none; /* hidden by default */
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-secondary);
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
        white-space: nowrap;
    }
    .nav-exit-dev-btn:hover {
        background: var(--surface);
        color: var(--text);
    }
</style>

<script define:vars={{ headerSearchIndex }}>
    window.headerSearchIndex = headerSearchIndex;
</script>

<script>
    const setupHeader = () => {
        const themeToggle = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');
        const createBtn = document.getElementById('nav-create-btn');
        const exitDevBtn = document.getElementById('nav-exit-dev-btn');
        const searchBar = document.getElementById('search-bar');
        const searchInput = document.getElementById('search-input');
        const searchResults = document.getElementById('search-results');
        
        const updateIcon = (theme) => {
            if(themeIcon) {
                themeIcon.textContent = theme === 'dark' ? 'light_mode' : 'dark_mode';
            }
        };
        
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        updateIcon(currentTheme);

        if (themeToggle) {
            // Remove previous event listener to avoid duplicates in Astro view transitions
            const newBtn = themeToggle.cloneNode(true);
            themeToggle.parentNode?.replaceChild(newBtn, themeToggle);
            
            newBtn.addEventListener('click', () => {
                const current = document.documentElement.getAttribute('data-theme');
                const next = current === 'dark' ? 'light' : 'dark';
                
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('theme', next);
                
                const newIcon = newBtn.querySelector('#theme-icon');
                if(newIcon) {
                    newIcon.textContent = next === 'dark' ? 'light_mode' : 'dark_mode';
                }
            });
        }

        // Dev Mode UI Logic - only works on localhost (editor is dev-only)
        const isLocalDev = ['localhost', '127.0.0.1'].includes(window.location.hostname);
        const checkDevMode = () => {
            const isDev = localStorage.getItem('okay_dev_mode') === 'true' && isLocalDev;
            if (isDev) {
                if(createBtn) createBtn.style.display = 'flex';
                if(exitDevBtn) exitDevBtn.style.display = 'block';
            } else {
                if(createBtn) createBtn.style.display = 'none';
                if(exitDevBtn) exitDevBtn.style.display = 'none';
            }
        };

        checkDevMode();
        window.addEventListener('dev-mode-changed', checkDevMode);

        if (exitDevBtn) {
            exitDevBtn.addEventListener('click', () => {
                localStorage.removeItem('okay_dev_mode');
                document.body.classList.remove('dev-mode-active');
                checkDevMode();
                window.dispatchEvent(new Event('dev-mode-changed')); // Notify others
            });
        }

        if (searchBar && searchInput && searchResults && !searchBar.dataset.searchReady) {
            const searchIndex = Array.isArray(window.headerSearchIndex) ? window.headerSearchIndex : [];
            const maxResults = 8;
            let currentResults = [];

            const escapeHtml = (value = '') => {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            };

            const hideResults = () => {
                currentResults = [];
                searchResults.classList.remove('visible');
                searchResults.innerHTML = '';
            };

            const renderResults = (query) => {
                const keyword = String(query || '').trim().toLowerCase();
                if (!keyword) {
                    hideResults();
                    return;
                }

                const ranked = searchIndex
                    .map((post) => {
                        const title = String(post.title || '').toLowerCase();
                        const description = String(post.description || '').toLowerCase();
                        const slug = String(post.slug || '').toLowerCase();
                        const tags = Array.isArray(post.tags) ? post.tags.map((tag) => String(tag).toLowerCase()) : [];

                        let score = 0;
                        if (title.startsWith(keyword)) score += 120;
                        if (title.includes(keyword)) score += 80;
                        if (description.includes(keyword)) score += 35;
                        if (slug.includes(keyword)) score += 20;
                        if (tags.some((tag) => tag.includes(keyword))) score += 50;

                        return { ...post, score };
                    })
                    .filter((post) => post.score > 0)
                    .sort((a, b) => {
                        if (b.score !== a.score) return b.score - a.score;
                        return (b.timestamp || 0) - (a.timestamp || 0);
                    })
                    .slice(0, maxResults);

                currentResults = ranked;

                if (ranked.length === 0) {
                    searchResults.innerHTML = '<div class="search-no-result">未找到相关文章</div>';
                    searchResults.classList.add('visible');
                    return;
                }

                searchResults.innerHTML = ranked
                    .map((post) => {
                        const summary = post.description || (post.tags || []).join(' / ') || post.url;
                        return `
                            <a class="search-result-item" href="${post.url}">
                                <h4>${escapeHtml(post.title)}</h4>
                                <p>${escapeHtml(summary)}</p>
                            </a>
                        `;
                    })
                    .join('');
                searchResults.classList.add('visible');
            };

            searchInput.addEventListener('input', (event) => {
                renderResults(event.target.value);
            });

            searchInput.addEventListener('focus', () => {
                if (searchInput.value.trim()) {
                    renderResults(searchInput.value);
                }
            });

            searchInput.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    hideResults();
                    searchInput.blur();
                    return;
                }

                if (event.key === 'Enter') {
                    const keyword = searchInput.value.trim();
                    if (!keyword) return;

                    if (currentResults.length > 0) {
                        window.location.href = currentResults[0].url;
                    } else {
                        window.location.href = `/search?q=${encodeURIComponent(keyword)}`;
                    }
                }
            });

            searchInput.addEventListener('blur', () => {
                window.setTimeout(() => {
                    if (!searchBar.contains(document.activeElement)) {
                        hideResults();
                    }
                }, 120);
            });

            searchBar.dataset.searchReady = 'true';
        }
    };

    setupHeader();
    document.addEventListener('astro:page-load', setupHeader);
</script>
