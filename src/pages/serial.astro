    <script is:inline>
function initSerialDebug() {
    if (!document.getElementById('terminals-wrapper')) return;
    if (window.__serialDebugInit) return;
    window.__serialDebugInit = true;

    // === Global State ===
    var COLORS = ['#3b82f6', '#ef4444', '#22c55e', '#f59e0b', '#8b5cf6', '#ec4899', '#06b6d4', '#f97316', '#14b8a6', '#6366f1'];
    var chart = null;
    var chartPaused = false;
    var sessions = [];
    var activeSession = null;
    var sessionIdCounter = 0;

    // === DOM Elements ===
    var connectBtn = document.getElementById('btn-connect');
    var connectIcon = document.getElementById('connect-icon');
    var connectTextEl = document.getElementById('connect-text');
    var portInfoEl = document.getElementById('port-info');
    var statusLed = document.getElementById('status-led');
    var statusTextEl = document.getElementById('status-text');
    var rxCountEl = document.getElementById('rx-count');
    var txCountEl = document.getElementById('tx-count');
    var sendInput = document.getElementById('send-input');
    var sendBtn = document.getElementById('btn-send');
    var baudSelect = document.getElementById('baud-rate');
    var dataBitsSelect = document.getElementById('data-bits');
    var stopBitsSelect = document.getElementById('stop-bits');
    var paritySelect = document.getElementById('parity');
    var flowControlSelect = document.getElementById('flow-control');
    var sendBar = document.getElementById('send-bar');
    var echoChk = document.getElementById('chk-echo');
    var terminalsWrapper = document.getElementById('terminals-wrapper');
    var tsList = document.getElementById('ts-list');

    function showToast(msg, type) {
        var tc = document.getElementById('toast-container');
        var icons = { error: 'error', warn: 'warning', ok: 'check_circle' };
        var t = document.createElement('div');
        t.className = 'toast toast-' + (type || 'ok');
        t.innerHTML = '<span class="material-icons-round">' + (icons[type] || 'info') + '</span><span>' + msg + '</span>';
        tc.appendChild(t);
        setTimeout(function () { t.style.opacity = '0'; t.style.transform = 'translateX(40px)'; t.style.transition = '0.3s'; setTimeout(function () { t.remove(); }, 300); }, 4000);
    }

    function log(s, msg, color) {
        if (s && s.term) {
            if (color) s.term.writeln('\x1b[' + color + 'm' + msg + '\x1b[0m');
            else s.term.writeln(msg);
        } else console.log('[Serial]', msg);
    }

    if (!('serial' in navigator)) {
        var banner = document.getElementById('unsupported-banner');
        if (banner) banner.style.display = 'flex';
    }

    // === Session Management ===

    function createSession() {
        sessionIdCounter++;
        var s = {
            id: sessionIdCounter,
            name: 'Terminal ' + sessionIdCounter,
            port: null,
            reader: null,
            writer: null,
            isConnected: false,
            isDisconnecting: false,
            rxCount: 0,
            txCount: 0,
            sendMode: 'text',
            lineBuffer: '',
            chartDatasets: [],
            chartLabels: [],
            chartPointIndex: 0,
            term: null,
            fitAddon: null,
            interactiveMode: true,
            localEcho: false,
            baudRate: 1500000,
            dataBits: 8,
            stopBits: 1,
            parity: 'none',
            flowControl: 'none',
            container: document.createElement('div')
        };
        s.container.className = 'session-container';
        s.container.style.width = '100%';
        s.container.style.height = '100%';
        s.container.style.display = 'none';
        terminalsWrapper.appendChild(s.container);

        sessions.push(s);
        renderTerminalList();
        switchSession(s);
        initTerminal(s);
        return s;
    }

    function removeSession(id) {
        if (sessions.length <= 1) {
            showToast('至少保留一个终端会话', 'warn');
            return;
        }
        var idx = sessions.findIndex(function (x) { return x.id === id; });
        if (idx === -1) return;
        var s = sessions[idx];
        if (s.isConnected) {
            if (!confirm('终端 [' + s.name + '] 当前处于连接状态，确定要关闭吗？')) return;
            try {
                s.isDisconnecting = true;
                if (s.reader) s.reader.cancel();
                if (s.port) s.port.close();
            } catch (e) { }
        }
        s.container.remove();
        if (s.term) s.term.dispose();
        sessions.splice(idx, 1);
        if (activeSession === s) {
            switchSession(sessions[Math.max(0, idx - 1)]);
        } else {
            renderTerminalList();
        }
    }

    function switchSession(s) {
        if (!s) return;
        if (activeSession && activeSession.container) {
            activeSession.container.style.display = 'none';
        }
        activeSession = s;
        s.container.style.display = 'block';

        updateConnectionUI(s);
        rxCountEl.textContent = s.rxCount;
        txCountEl.textContent = s.txCount;

        if (s.port) {
            var info = s.port.getInfo();
            var portName = info.usbVendorId ? 'USB(' + info.usbVendorId.toString(16).toUpperCase() + ':' + (info.usbProductId || 0).toString(16).toUpperCase() + ')' : 'Serial';
            portInfoEl.textContent = portName;
            portInfoEl.classList.toggle('connected', s.isConnected);
        } else {
            portInfoEl.textContent = '未选择';
            portInfoEl.classList.remove('connected');
        }

        baudSelect.value = s.baudRate;
        dataBitsSelect.value = s.dataBits;
        stopBitsSelect.value = s.stopBits;
        paritySelect.value = s.parity;
        flowControlSelect.value = s.flowControl;
        echoChk.checked = s.localEcho;

        if (s.sendMode === 'text') {
            document.getElementById('smode-text').classList.add('active');
            document.getElementById('smode-hex').classList.remove('active');
        } else {
            document.getElementById('smode-hex').classList.add('active');
            document.getElementById('smode-text').classList.remove('active');
        }

        if (s.interactiveMode) {
            document.getElementById('mode-interactive').classList.add('active');
            document.getElementById('mode-monitor').classList.remove('active');
        } else {
            document.getElementById('mode-monitor').classList.add('active');
            document.getElementById('mode-interactive').classList.remove('active');
        }

        if (chart) {
            chart.data.labels = s.chartLabels;
            chart.data.datasets = s.chartDatasets;
            chart.update('none');
        }

        if (s.fitAddon) {
            try { s.fitAddon.fit(); } catch (e) { }
        }
        if (s.term) {
            s.term.focus();
            setTimeout(function () { try { s.fitAddon.fit(); } catch (e) { } }, 50);
        }

        renderTerminalList();
    }

    function renderTerminalList() {
        tsList.innerHTML = '';
        sessions.forEach(function (s) {
            var item = document.createElement('div');
            item.className = 'ts-item' + (s === activeSession ? ' active' : '');
            var icon = document.createElement('span');
            icon.className = 'material-icons-round ts-icon';
            icon.textContent = 'terminal';

            var name = document.createElement('span');
            name.textContent = s.name;
            name.style.flex = '1';

            var delBtn = document.createElement('button');
            delBtn.className = 'ts-item-del';
            delBtn.innerHTML = '<span class="material-icons-round" style="font-size:14px">close</span>';
            delBtn.title = '关闭';

            delBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                removeSession(s.id);
            });

            item.appendChild(icon);
            item.appendChild(name);
            item.appendChild(delBtn);

            item.addEventListener('click', function () {
                if (activeSession !== s) switchSession(s);
            });
            tsList.appendChild(item);
        });
    }

    document.getElementById('btn-new-term').addEventListener('click', function () {
        createSession();
    });

    // === Serial Connection Logic ===

    async function connectSerial(s) {
        if (!s) return;
        if (!('serial' in navigator)) {
            showToast('\u6d4f\u89c8\u5668\u4e0d\u652f\u6301 Web Serial API\uff0c\u8bf7\u7528 Chrome 89+', 'error');
            return;
        }
        if (s.isConnected || s.port) {
            log(s, '\u26a0 \u6e05\u7406\u4e0a\u4e00\u6b21\u8fde\u63a5...', '0;33');
            await cleanupConnection(s);
        }
        try {
            var forceFindEnabled = document.getElementById('chk-force-serial').checked;
            
            if (forceFindEnabled) {
                // Known embedded serial hardware IDs
                var filters = [
                    { usbVendorId: 0x1A86 }, // QinHeng (CH340/CH341/CH9102)
                    { usbVendorId: 0x10C4 }, // Silicon Labs (CP210x)
                    { usbVendorId: 0x0403 }, // FTDI
                    { usbVendorId: 0x067B }, // Prolific (PL2303)
                    { usbVendorId: 0x2341 }, // Arduino SA
                    { usbVendorId: 0x303A }, // Espressif (ESP32)
                    { usbVendorId: 0x0483 }  // STMicroelectronics (STM32)
                ];
                s.port = await navigator.serial.requestPort({ filters: filters } as unknown as void);
            } else {
                // Default: shows everything the OS openly allows
                s.port = await navigator.serial.requestPort();
            }

            var info = s.port.getInfo();
            var portName = info.usbVendorId
                ? 'USB(' + info.usbVendorId.toString(16).toUpperCase() + ':' + (info.usbProductId || 0).toString(16).toUpperCase() + ')'
                : 'Serial';
            if (s === activeSession) {
                portInfoEl.textContent = portName;
                portInfoEl.classList.add('connected');
            }

            s.baudRate = parseInt(baudSelect.value) || 115200;
            s.dataBits = parseInt(dataBitsSelect.value);
            s.stopBits = parseInt(stopBitsSelect.value);
            s.parity = paritySelect.value;
            s.flowControl = flowControlSelect.value;

            var opened = false;
            for (var attempt = 0; attempt < 2 && !opened; attempt++) {
                try {
                    await s.port.open({
                        baudRate: s.baudRate,
                        dataBits: s.dataBits,
                        stopBits: s.stopBits,
                        parity: s.parity,
                        flowControl: s.flowControl
                    });
                    opened = true;
                } catch (openErr) {
                    if (attempt === 0 && openErr.name === 'InvalidStateError') {
                        log(s, '\u26a0 \u7aef\u53e3\u6b8b\u7559\u72b6\u6001\uff0c\u5c1d\u8bd5\u91cd\u7f6e...', '0;33');
                        try { await s.port.close(); } catch (e) { }
                        await new Promise(function (r) { setTimeout(r, 300); });
                        continue;
                    }
                    if (s === activeSession) {
                        portInfoEl.textContent = '\u672a\u9009\u62e9';
                        portInfoEl.classList.remove('connected');
                    }
                    var errMsg = openErr.message || '';
                    if (openErr.name === 'NetworkError') {
                        showToast('\u2717 \u4e32\u53e3\u88ab\u5176\u4ed6\u7a0b\u5e8f\u5360\u7528\uff01\u8bf7\u5148\u5173\u95ed VOFA+/SSCOM \u7b49\u8f6f\u4ef6', 'error');
                        log(s, '\u2717 \u4e32\u53e3 ' + portName + ' \u88ab\u5176\u4ed6\u7a0b\u5e8f\u5360\u7528', '1;31');
                    } else if (openErr.name === 'InvalidStateError') {
                        showToast('\u2717 \u7aef\u53e3\u88ab\u9501\u5b9a\uff01\u8bf7\u5173\u95ed\u5176\u4ed6\u6253\u5f00\u4e86\u6b64\u9875\u9762\u7684\u6d4f\u89c8\u5668\u6807\u7b7e\u9875', 'error');
                        log(s, '\u2717 \u4e32\u53e3 ' + portName + ' \u88ab\u5176\u4ed6\u6d4f\u89c8\u5668\u6807\u7b7e\u9875\u9501\u5b9a', '1;31');
                    } else {
                        showToast('\u2717 \u6253\u5f00\u4e32\u53e3\u5931\u8d25: ' + errMsg, 'error');
                        log(s, '\u2717 \u6253\u5f00\u4e32\u53e3\u5931\u8d25: ' + errMsg, '1;31');
                    }
                    s.port = null;
                    return;
                }
            }

            s.isConnected = true;
            s.isDisconnecting = false;
            s.name = portName; // update tab name
            if (s === activeSession) updateConnectionUI(s);
            renderTerminalList();

            log(s, '\u2713 \u6210\u529f\u8fde\u63a5\u5230 ' + portName + ' (' + s.baudRate + 'bps)', '1;32');
            showToast('\u5df2\u8fde\u63a5\u5230 ' + portName, 'ok');

            s.writer = s.port.writable.getWriter();
            readLoop(s);
        } catch (err) {
            if (err.name !== 'NotFoundError') {
                showToast('\u2717 \u8fde\u63a5\u5931\u8d25: ' + err.message, 'error');
                log(s, '\u2717 \u8fde\u63a5\u5931\u8d25: ' + err.message, '1;31');
            }
        }
    }

    async function disconnectSerial(s) {
        if (!s || !s.isConnected) return;
        s.isDisconnecting = true;
        log(s, '\u2500 \u6b63\u5728\u65ad\u5f00\u8fde\u63a5...', '0;33');
        try {
            if (s.reader) { await s.reader.cancel(); s.reader = null; }
            if (s.writer) { await s.writer.close(); s.writer.releaseLock(); s.writer = null; }
            if (s.port) { await s.port.close(); s.port = null; }
        } catch (e) { console.warn('Disconnect error', e); }
        s.isConnected = false;
        s.isDisconnecting = false;
        if (s === activeSession) {
            updateConnectionUI(s);
            portInfoEl.textContent = '\u672a\u9009\u62e9';
            portInfoEl.classList.remove('connected');
        }
        log(s, '\u2713 \u5df2\u65ad\u5f00\u8fde\u63a5\n', '1;32');
        showToast('\u5df2\u65ad\u5f00\u8fde\u63a5', 'ok');
    }

    async function cleanupConnection(s) {
        if (!s) return;
        try {
            s.isDisconnecting = true;
            if (s.reader) { await s.reader.cancel(); s.reader = null; }
            if (s.writer) { s.writer.releaseLock(); s.writer = null; }
            if (s.port) { await s.port.close(); s.port = null; }
        } catch (e) { }
        s.isConnected = false;
        s.isDisconnecting = false;
    }

    async function readLoop(s) {
        if (!s.port) return;
        var decoder = new TextDecoder('utf-8', { stream: true });
        while (s.port.readable && s.isConnected && !s.isDisconnecting) {
            s.reader = s.port.readable.getReader();
            try {
                while (true) {
                    var r = await s.reader.read();
                    if (r.done) break;
                    if (r.value) {
                        s.rxCount += r.value.length;
                        if (s === activeSession) rxCountEl.textContent = s.rxCount.toString();
                        var text = decoder.decode(r.value, { stream: true });

                        // VOFA+ Protocol
                        for (var ci = 0; ci < text.length; ci++) {
                            if (text[ci] === '\n') {
                                var trimmed = s.lineBuffer.trim();
                                if (trimmed) {
                                    var parts = trimmed.split(',').map(function (pt) { return parseFloat(pt.trim()); });
                                    if (parts.length > 0 && parts.every(function (v) { return !isNaN(v); })) addChartData(s, parts);
                                }
                                s.lineBuffer = '';
                            } else s.lineBuffer += text[ci];
                        }

                        if (s.term) {
                            var display;
                            var chkHex = document.getElementById('chk-hex-display');
                            if (chkHex && chkHex.checked) {
                                display = Array.from(r.value).map(function (b) { return b.toString(16).toUpperCase().padStart(2, '0'); }).join(' ');
                            } else display = text;
                            var chkTs = document.getElementById('chk-timestamp');
                            if (chkTs && chkTs.checked) {
                                var now = new Date();
                                display = '\x1b[90m[' + now.toLocaleTimeString('en-US', { hour12: false }) + '.' + now.getMilliseconds().toString().padStart(3, '0') + ']\x1b[0m ' + display;
                            }
                            s.term.write(display);
                        }
                    }
                }
            } catch (err) {
                if (s.isConnected && err.name !== 'NetworkError') {
                    log(s, '\u8bfb\u53d6\u9519\u8bef: ' + err.message, '1;31');
                }
            } finally {
                try { s.reader.releaseLock(); } catch (e) { }
                s.reader = null;
            }
            if (!s.isConnected) break;
        }
        try { decoder.decode(); } catch (e) { }
        if (s.isConnected) {
            s.isConnected = false;
            if (s === activeSession) {
                updateConnectionUI(s);
                portInfoEl.textContent = '\u672a\u9009\u62e9';
                portInfoEl.classList.remove('connected');
            }
            log(s, '\u26a0 \u4e32\u53e3\u8fde\u63a5\u5df2\u65ad\u5f00\uff08\u8bbe\u5907\u53ef\u80fd\u5df2\u62d4\u51fa\uff09', '1;33');
            showToast('\u4e32\u53e3\u8fde\u63a5\u5df2\u65ad\u5f00', 'warn');
        }
        renderTerminalList();
    }

    function updateConnectionUI(s) {
        if (!s) return;
        var connected = s.isConnected;
        connectIcon.textContent = connected ? 'usb_off' : 'usb';
        connectTextEl.textContent = connected ? '\u65ad\u5f00\u8fde\u63a5' : '\u9009\u62e9\u7aef\u53e3';
        connectBtn.classList.toggle('connected-btn', connected);
        statusLed.classList.toggle('connected', connected);
        statusTextEl.textContent = connected ? '\u5df2\u8fde\u63a5' : '\u672a\u8fde\u63a5';
        sendBtn.disabled = !connected;
        [baudSelect, dataBitsSelect, stopBitsSelect, paritySelect, flowControlSelect].forEach(function (el) { el.disabled = connected; });
    }

    async function sendData(s, data) {
        if (!s || !s.isConnected || !s.writer) return;
        var bytes;
        if (s.sendMode === 'hex') {
            var h = data.replace(/\s+/g, '');
            if (h.length % 2 !== 0 || !/^[0-9a-fA-F]+$/.test(h)) { showToast('HEX \u683c\u5f0f\u9519\u8bef', 'error'); return; }
            bytes = new Uint8Array(h.match(/.{2}/g).map(function (b) { return parseInt(b, 16); }));
        } else {
            var toSend = data;
            var nl = document.getElementById('newline-select').value;
            if (nl) toSend += nl;
            bytes = new TextEncoder().encode(toSend);
        }
        try {
            await s.writer.write(bytes);
            s.txCount += bytes.length;
            if (activeSession === s) txCountEl.textContent = s.txCount.toString();
            if (s.localEcho && s.term && s.sendMode !== 'hex') s.term.write('\x1b[90m' + data + '\x1b[0m');
        } catch (err) {
            showToast('\u53d1\u9001\u5931\u8d25: ' + err.message, 'error');
            log(s, '\u53d1\u9001\u5931\u8d25: ' + err.message, '1;31');
        }
    }

    async function sendRaw(s, rawBytes) {
        if (!s || !s.isConnected || !s.writer) return;
        try {
            var b = typeof rawBytes === 'string' ? new TextEncoder().encode(rawBytes) : rawBytes;
            await s.writer.write(b);
            s.txCount += b.length;
            if (activeSession === s) txCountEl.textContent = s.txCount.toString();
        } catch (e) { }
    }

    function addChartData(s, values) {
        if (chartPaused || !chart || activeSession !== s) return;
        while (s.chartDatasets.length < values.length) {
            var idx = s.chartDatasets.length;
            var c = COLORS[idx % COLORS.length];
            s.chartDatasets.push({ label: 'CH' + (idx + 1), data: [], borderColor: c, backgroundColor: c + '22', borderWidth: 1.5, pointRadius: 0 });
            chart.data.datasets = s.chartDatasets;
        }
        s.chartPointIndex++;
        s.chartLabels.push(s.chartPointIndex);
        for (var i = 0; i < s.chartDatasets.length; i++) s.chartDatasets[i].data.push(i < values.length ? values[i] : NaN);
        var maxPts = parseInt(document.getElementById('chart-points').value) || 200;
        while (s.chartLabels.length > maxPts) { s.chartLabels.shift(); s.chartDatasets.forEach(function (ds) { ds.data.shift(); }); }
        chart.update('none');
    }

    // === Events ===
    connectBtn.addEventListener('click', function () { if (activeSession) activeSession.isConnected ? disconnectSerial(activeSession) : connectSerial(activeSession); });
    sendBtn.addEventListener('click', function () { var v = sendInput.value.trim(); if (v && activeSession) { sendData(activeSession, v); sendInput.value = ''; sendInput.focus(); } });
    sendInput.addEventListener('keydown', function (e) { if (e.key === 'Enter' && sendInput.value.trim() && activeSession) { sendData(activeSession, sendInput.value.trim()); sendInput.value = ''; } });

    document.getElementById('smode-text').addEventListener('click', function () { if (activeSession) activeSession.sendMode = 'text'; this.classList.add('active'); document.getElementById('smode-hex').classList.remove('active'); });
    document.getElementById('smode-hex').addEventListener('click', function () { if (activeSession) activeSession.sendMode = 'hex'; this.classList.add('active'); document.getElementById('smode-text').classList.remove('active'); });

    document.querySelectorAll('.quick-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { if (activeSession) sendRaw(activeSession, btn.dataset.cmd || ''); });
    });
    document.getElementById('btn-add-quick').addEventListener('click', function () {
        var cmd = prompt('\u8f93\u5165\u5feb\u6377\u6307\u4ee4 (\u4f8b\u5982: AT+RST)');
        if (cmd) {
            var qs = document.getElementById('quick-send');
            var ab = document.getElementById('btn-add-quick');
            var nb = document.createElement('button');
            nb.className = 'quick-btn';
            nb.dataset.cmd = cmd + '\r\n';
            nb.textContent = cmd;
            nb.addEventListener('click', function () { if (activeSession) sendRaw(activeSession, nb.dataset.cmd); });
            qs.insertBefore(nb, ab);
        }
    });
    document.getElementById('btn-clear').addEventListener('click', function () { if (activeSession && activeSession.term) activeSession.term.clear(); });
    document.getElementById('btn-reset-count').addEventListener('click', function () {
        if (activeSession) {
            activeSession.rxCount = 0; activeSession.txCount = 0;
            rxCountEl.textContent = '0'; txCountEl.textContent = '0';
        }
    });

    document.getElementById('mode-interactive').addEventListener('click', function () {
        if (activeSession) activeSession.interactiveMode = true;
        this.classList.add('active');
        document.getElementById('mode-monitor').classList.remove('active');
        sendBar.classList.remove('interactive-hidden');
        log(activeSession, '▶ 已切换到交互模式', '0;36');
        if (activeSession && activeSession.term) activeSession.term.focus();
    });
    document.getElementById('mode-monitor').addEventListener('click', function () {
        if (activeSession) activeSession.interactiveMode = false;
        this.classList.add('active');
        document.getElementById('mode-interactive').classList.remove('active');
        sendBar.classList.remove('interactive-hidden');
        log(activeSession, '▶ 已切换到监控模式', '0;36');
    });

    echoChk.addEventListener('change', function () {
        if (activeSession) activeSession.localEcho = this.checked;
        log(activeSession, this.checked ? '\u2713 \u672c\u5730\u56de\u663e\u5df2\u5f00\u542f' : '\u2717 \u672c\u5730\u56de\u663e\u5df2\u5173\u95ed', '0;90');
    });

    baudSelect.addEventListener('change', function () { if (activeSession) activeSession.baudRate = this.value; });
    dataBitsSelect.addEventListener('change', function () { if (activeSession) activeSession.dataBits = this.value; });
    stopBitsSelect.addEventListener('change', function () { if (activeSession) activeSession.stopBits = this.value; });
    paritySelect.addEventListener('change', function () { if (activeSession) activeSession.parity = this.value; });
    flowControlSelect.addEventListener('change', function () { if (activeSession) activeSession.flowControl = this.value; });

    // Keyboard shortcut Ctrl+Shift+~
    document.addEventListener('keydown', function (e) {
        if (e.ctrlKey && e.shiftKey && (e.key === '`' || e.key === '~')) {
            e.preventDefault();
            document.getElementById('btn-new-term').click();
        }
    });

