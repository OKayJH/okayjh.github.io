---
import Layout from '../layouts/Layout.astro';
---

<Layout title="串口调试助手 | OKay's Blog">
    <!-- xterm.js (local) -->
    <link rel="stylesheet" href="/libs/xterm/xterm.min.css" />
    <script is:inline src="/libs/xterm/xterm.min.js"></script>
    <script is:inline src="/libs/xterm/addon-fit.min.js"></script>
    <script is:inline src="/libs/xterm/addon-web-links.min.js"></script>
    <!-- Chart.js CDN -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

    <main class="serial-main">
        <header class="serial-header">
            <div class="header-left">
                <a href="/" class="back-link">
                    <span class="material-icons-round">arrow_back</span> 返回主页
                </a>
            </div>
            <div class="header-center">
                <h1 class="serial-title">
                    <span class="material-icons-round">terminal</span> OKay Terminal
                </h1>
                <p class="serial-subtitle">专业的浏览器端串口调试工具 · 支持交互命令与波形分析</p>
            </div>
            <div class="header-right"></div>
        </header>

        <!-- Toast for error messages -->
        <div class="toast-container" id="toast-container"></div>

        <section class="toolbar-card" id="toolbar">
            <div class="toolbar-row">
                <div class="toolbar-group">
                    <label>端口</label>
                    <div class="port-row">
                        <button class="btn btn-primary" id="btn-connect">
                            <span class="material-icons-round" id="connect-icon">usb</span>
                            <span id="connect-text">选择端口</span>
                        </button>
                        <span class="port-info" id="port-info">未选择</span>
                    </div>
                </div>
                <div class="toolbar-group">
                    <label>波特率</label>
                    <select id="baud-rate" class="baud-select">
                        <option value="1200">1200</option>
                        <option value="2400">2400</option>
                        <option value="4800">4800</option>
                        <option value="9600">9600</option>
                        <option value="19200">19200</option>
                        <option value="38400">38400</option>
                        <option value="57600">57600</option>
                        <option value="74800">74800</option>
                        <option value="115200">115200</option>
                        <option value="230400">230400</option>
                        <option value="460800">460800</option>
                        <option value="500000">500000</option>
                        <option value="576000">576000</option>
                        <option value="921600">921600</option>
                        <option value="1000000">1000000</option>
                        <option value="1152000">1152000</option>
                        <option value="1500000" selected>1500000</option>
                        <option value="2000000">2000000</option>
                        <option value="2500000">2500000</option>
                        <option value="3000000">3000000</option>
                        <option value="3500000">3500000</option>
                        <option value="4000000">4000000</option>
                    </select>
                </div>
                <div class="toolbar-group">
                    <label>强制驱动</label>
                    <label class="toggle-label" title="开启此项后，将强制浏览器绕过Windows底层隐藏策略，只显示常见的单片机串口芯片（如CH340/CP2102/FTDI等）。用于解决由于系统驱动问题导致网页检测不到设备的问题。" style="display: flex; align-items: center; gap: 4px; padding: 2px 4px;">
                        <input type="checkbox" id="chk-force-serial">
                        <span class="material-icons-round" style="font-size: 16px; color: var(--text-color);">memory</span>
                        <span style="font-size: 0.85rem; color: var(--text-color);">CH340/嵌入式</span>
                    </label>
                </div>
                <div class="toolbar-group">
                    <label>数据位</label>
                    <select id="data-bits">
                        <option value="7">7</option>
                        <option value="8" selected>8</option>
                    </select>
                </div>
                <div class="toolbar-group">
                    <label>停止位</label>
                    <select id="stop-bits">
                        <option value="1" selected>1</option>
                        <option value="2">2</option>
                    </select>
                </div>
                <div class="toolbar-group">
                    <label>校验位</label>
                    <select id="parity">
                        <option value="none" selected>None</option>
                        <option value="even">Even</option>
                        <option value="odd">Odd</option>
                    </select>
                </div>
                <div class="toolbar-group">
                    <label>流控</label>
                    <select id="flow-control">
                        <option value="none" selected>None</option>
                        <option value="hardware">Hardware</option>
                    </select>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <label>模式</label>
                    <div class="mode-switch">
                        <button class="mode-btn active" id="mode-interactive" title="交互模式：标准终端数据交互流通信">
                            <span class="material-icons-round">keyboard</span> 交互
                        </button>
                        <button class="mode-btn" id="mode-monitor" title="监控模式：独立接收视图与快捷指令分发">
                            <span class="material-icons-round">monitor_heart</span> 监控
                        </button>
                    </div>
                </div>
                <div class="toolbar-group">
                    <label>回显</label>
                    <label class="echo-toggle" title="本地回显：开启后在终端显示你发送的字符">
                        <input type="checkbox" id="chk-echo">
                        <span class="echo-slider"></span>
                    </label>
                </div>
                <div class="toolbar-status">
                    <div class="status-indicator" id="status-led"></div>
                    <span id="status-text">未连接</span>
                </div>
                <div class="toolbar-counters">
                    <span class="counter rx-counter">RX: <b id="rx-count">0</b></span>
                    <span class="counter tx-counter">TX: <b id="tx-count">0</b></span>
                    <button class="btn btn-icon" id="btn-reset-count" title="重置计数">
                        <span class="material-icons-round">restart_alt</span>
                    </button>
                </div>
            </div>
        </section>

        <section class="serial-body">
            <div class="view-tabs">
                <button class="view-tab active" data-view="terminal" id="tab-terminal">
                    <span class="material-icons-round">terminal</span> 终端
                </button>
                <button class="view-tab" data-view="chart" id="tab-chart">
                    <span class="material-icons-round">show_chart</span> 波形图
                </button>
                <button class="view-tab" data-view="split" id="tab-split">
                    <span class="material-icons-round">vertical_split</span> 分屏
                </button>
                <div class="view-tab-actions">
                    <label class="toggle-label" title="显示时间戳">
                        <input type="checkbox" id="chk-timestamp">
                        <span class="material-icons-round">schedule</span>
                    </label>
                    <label class="toggle-label" title="HEX 显示">
                        <input type="checkbox" id="chk-hex-display">
                        <span class="material-icons-round">data_object</span>
                    </label>
                    <label class="toggle-label" title="自动滚动">
                        <input type="checkbox" id="chk-autoscroll" checked>
                        <span class="material-icons-round">vertical_align_bottom</span>
                    </label>
                    <button class="btn btn-icon" id="btn-clear" title="清屏">
                        <span class="material-icons-round">delete_sweep</span>
                    </button>
                </div>
            </div>
            <div class="main-workspace">
                <!-- Activity Bar (Far Left) -->
                <div class="activity-bar">
                    <button class="activity-icon active" data-panel="panel-cmd" title="常用命令库">
                        <span class="material-icons-round">bookmark</span>
                    </button>
                </div>

                <!-- Primary Sidebar -->
                <div class="primary-sidebar" id="primary-sidebar">
                    <!-- Command Library Panel -->
                    <div class="sidebar-panel active" id="panel-cmd">
                        <div class="shell-sidebar-header">
                            <span class="shell-sidebar-title" style="margin-left:4px; text-transform:uppercase; font-size:0.75rem; letter-spacing:0.5px;">常用命令库</span>
                            <span class="shell-cmds-count" id="shell-cmds-count">0</span>
                            <button class="btn-icon-mini" id="btn-edit-cmds" title="编辑命令">
                                <span class="material-icons-round">edit</span>
                            </button>
                        </div>
                        <div class="shell-sidebar-body" id="shell-cmds-body">
                            <div class="shell-add-row" id="shell-add-row">
                                <select id="shell-cmd-category" class="shell-cat-select" title="分类">
                                    <option value="系统信息">系统</option>
                                    <option value="文件操作">文件</option>
                                    <option value="网络相关">网络</option>
                                    <option value="进程管理">进程</option>
                                    <option value="外设硬件">外设</option>
                                    <option value="高级调试">高级</option>
                                    <option value="自定义">自定义</option>
                                </select>
                                <input type="text" class="shell-cmd-input" id="shell-cmd-input" placeholder="命令">
                                <input type="text" class="shell-cmd-desc-input" id="shell-cmd-desc" placeholder="描述">
                                <button class="btn btn-sm btn-accent" id="btn-add-shell-cmd" title="添加命令">
                                    <span class="material-icons-round">add</span>
                                </button>
                            </div>
                            <div class="shell-cmds-list" id="shell-cmds-list"></div>
                        </div>
                    </div>
                </div>

                <!-- Horizontal resize divider -->
                <div class="sidebar-resize-handle" id="sidebar-resize-handle" title="拖拽调整宽度"></div>

                <!-- Main Editor Area -->
                <div class="views-container">
                    <div class="terminal-panel" id="terminal-panel">
                        <div style="display: flex; flex: 1; min-height: 0;">
                            <div id="terminals-wrapper" style="flex: 1; position: relative;"></div>
                            <div class="terminal-sidebar" id="terminal-sidebar">
                                <div class="ts-header">
                                    <span>终端会话</span>
                                    <button class="btn-icon-mini" id="btn-new-term" title="新建终端 (Ctrl+Shift+~)"><span class="material-icons-round">add</span></button>
                                </div>
                                <div class="ts-list" id="ts-list"></div>
                            </div>
                        </div>
                        <div class="terminal-resize-handle" id="terminal-resize-handle" title="拖拽调整高度"></div>
                    </div>
                    <div class="chart-panel" id="chart-panel" style="display: none;">
                        <div class="chart-toolbar">
                            <div class="chart-info">
                                <span class="material-icons-round">info</span>
                                VOFA+ FireWater 协议：逗号分隔浮点数，以 <code>\n</code> 结尾
                            </div>
                            <div class="chart-controls">
                                <label>数据点数:
                                    <select id="chart-points">
                                        <option value="100">100</option>
                                        <option value="200" selected>200</option>
                                        <option value="500">500</option>
                                        <option value="1000">1000</option>
                                    </select>
                                </label>
                                <button class="btn btn-sm" id="btn-chart-clear">
                                    <span class="material-icons-round">playlist_remove</span> 清除
                                </button>
                                <button class="btn btn-sm" id="btn-chart-pause">
                                    <span class="material-icons-round" id="chart-pause-icon">pause</span>
                                    <span id="chart-pause-text">暂停</span>
                                </button>
                            </div>
                        </div>
                        <canvas id="waveform-chart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <section class="send-bar" id="send-bar">
            <div class="send-row">
                <div class="send-mode-toggle">
                    <button class="send-mode active" data-mode="text" id="smode-text">TEXT</button>
                    <button class="send-mode" data-mode="hex" id="smode-hex">HEX</button>
                </div>
                <input type="text" class="send-input" id="send-input" placeholder="输入要发送的数据..." autocomplete="off">
                <select class="newline-select" id="newline-select" title="换行符">
                    <option value="\r\n">\\r\\n</option>
                    <option value="\n">\\n</option>
                    <option value="\r">\\r</option>
                    <option value="">无</option>
                </select>
                <button class="btn btn-accent" id="btn-send" disabled>
                    <span class="material-icons-round">send</span> 发送
                </button>
            </div>
            <div class="quick-send" id="quick-send">
                <span class="quick-label">快捷:</span>
                <button class="quick-btn" data-cmd="AT\r\n">AT</button>
                <button class="quick-btn" data-cmd="AT+GMR\r\n">AT+GMR</button>
                <button class="quick-btn" data-cmd="help\r\n">help</button>
                <button class="quick-btn" data-cmd="reboot\r\n">reboot</button>
                <button class="quick-btn" data-cmd="\x03">Ctrl+C</button>
                <button class="btn btn-icon btn-add-quick" id="btn-add-quick" title="添加快捷指令">
                    <span class="material-icons-round">add</span>
                </button>
            </div>
        </section>

        <div class="unsupported-banner" id="unsupported-banner" style="display: none;">
            <span class="material-icons-round">warning</span>
            <div>
                <strong>你的浏览器不支持 Web Serial API</strong>
                <p>请使用 Chrome 89+、Edge 89+ 或 Opera 76+ 浏览器</p>
            </div>
        </div>
    </main>

    <style is:global>
        .serial-main { max-width: 1400px; margin: 80px auto 0; padding: 20px 24px 100px; min-height: 100vh; }
        .serial-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24px; position: relative; }
        .header-left, .header-right { width: 120px; flex-shrink: 0; }
        .header-center { flex: 1; text-align: center; }
        .back-link { display: inline-flex; align-items: center; gap: 4px; color: var(--text-secondary); text-decoration: none; font-size: 0.95rem; font-weight: 500; padding: 8px 12px; border-radius: 10px; transition: all 0.2s; background: var(--surface); border: 1px solid var(--border); margin-top: 4px; }
        .back-link:hover { color: var(--text); background: var(--hover-bg); border-color: var(--text-secondary); }
        .serial-title { font-size: 2.2rem; font-weight: 800; background: linear-gradient(135deg, var(--accent), #7c3aed); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; display: inline-flex; align-items: center; gap: 10px; margin: 0; }
        .serial-title .material-icons-round { -webkit-text-fill-color: var(--accent); font-size: 2.2rem; }
        .serial-subtitle { color: var(--text-secondary); margin-top: 8px; font-size: 1rem; font-weight: 500; }

        /* Toast */
        .toast-container { position: fixed; top: 80px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
        .toast { padding: 12px 20px; border-radius: 12px; font-size: 0.85rem; font-weight: 500; box-shadow: 0 4px 20px rgba(0,0,0,0.15); animation: toast-in 0.3s ease; display: flex; align-items: center; gap: 8px; max-width: 420px; }
        .toast-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
        .toast-warn { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
        .toast-ok { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
        .toast .material-icons-round { font-size: 20px; }
        @keyframes toast-in { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: none; } }

        /* Toolbar */
        .toolbar-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 14px 20px; margin-bottom: 16px; backdrop-filter: blur(12px); }
        .toolbar-row { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
        .toolbar-group { display: flex; flex-direction: column; gap: 4px; }
        .toolbar-group label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); letter-spacing: 0.5px; }
        .toolbar-group select { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 6px 10px; color: var(--text); font-size: 0.85rem; font-weight: 500; cursor: pointer; outline: none; transition: border-color 0.2s; min-width: 70px; }
        .toolbar-group select:focus { border-color: var(--accent); }
        .toolbar-divider { width: 1px; height: 40px; background: var(--border); margin: 0 4px; }
        .port-row { display: flex; align-items: center; gap: 8px; }
        .port-info { font-size: 0.8rem; font-weight: 500; color: var(--text-secondary); padding: 4px 8px; background: var(--bg); border-radius: 6px; border: 1px solid var(--border); min-width: 60px; text-align: center; }
        .port-info.connected { color: #22c55e; border-color: #22c55e33; background: #22c55e0d; }
        .baud-input { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 6px 10px; color: var(--text); font-size: 0.85rem; font-weight: 500; outline: none; transition: border-color 0.2s; width: 100px; -moz-appearance: textfield; }
        .baud-input::-webkit-inner-spin-button, .baud-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
        .baud-input:focus { border-color: var(--accent); }

        /* Mode Switch */
        .mode-switch { display: flex; background: var(--bg); border-radius: 8px; overflow: hidden; border: 1px solid var(--border); }
        .mode-btn { display: inline-flex; align-items: center; gap: 3px; padding: 5px 10px; border: none; background: none; color: var(--text-secondary); font-size: 0.75rem; font-weight: 700; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
        .mode-btn .material-icons-round { font-size: 15px; }
        .mode-btn.active { background: var(--accent); color: #fff; }

        /* Echo Toggle */
        .echo-toggle { position: relative; display: inline-block; width: 36px; height: 20px; cursor: pointer; }
        .echo-toggle input { opacity: 0; width: 0; height: 0; }
        .echo-slider { position: absolute; inset: 0; background: var(--border); border-radius: 20px; transition: 0.3s; }
        .echo-slider::before { content: ''; position: absolute; height: 14px; width: 14px; left: 3px; bottom: 3px; background: #fff; border-radius: 50%; transition: 0.3s; }
        .echo-toggle input:checked + .echo-slider { background: var(--accent); }
        .echo-toggle input:checked + .echo-slider::before { transform: translateX(16px); }

        /* Status */
        .toolbar-status { display: flex; align-items: center; gap: 8px; margin-left: auto; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); }
        .status-indicator { width: 10px; height: 10px; border-radius: 50%; background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.4); transition: all 0.3s; }
        .status-indicator.connected { background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,0.5); animation: pulse-green 2s infinite; }
        @keyframes pulse-green { 0%,100% { box-shadow: 0 0 6px rgba(34,197,94,0.4); } 50% { box-shadow: 0 0 14px rgba(34,197,94,0.7); } }
        .toolbar-counters { display: flex; align-items: center; gap: 10px; font-size: 0.8rem; }
        .counter { padding: 4px 10px; border-radius: 8px; background: var(--bg); font-weight: 600; }
        .rx-counter b { color: #22c55e; }
        .tx-counter b { color: #3b82f6; }

        /* Buttons */
        .btn { display: inline-flex; align-items: center; gap: 4px; padding: 8px 16px; border-radius: 10px; border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
        .btn:hover { background: var(--bg); border-color: var(--accent); }
        .btn-primary { background: var(--accent); color: #fff; border: none; box-shadow: 0 2px 8px rgba(0,122,204,0.3); }
        .btn-primary:hover { filter: brightness(1.1); transform: translateY(-1px); }
        .btn-primary.connected-btn { background: #ef4444; box-shadow: 0 2px 8px rgba(239,68,68,0.3); }
        .btn-accent { background: var(--accent); color: #fff; border: none; }
        .btn-accent:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn-icon { padding: 6px; border-radius: 8px; border: 1px solid var(--border); background: transparent; color: var(--text-secondary); cursor: pointer; transition: all 0.2s; display: inline-flex; }
        .btn-icon:hover { background: var(--surface); color: var(--text); }
        .btn-sm { padding: 4px 10px; font-size: 0.8rem; border-radius: 8px; }

        /* Tabs */
        .view-tabs { display: flex; align-items: center; gap: 4px; border-bottom: 1px solid var(--border); }
        .view-tab { display: inline-flex; align-items: center; gap: 4px; padding: 10px 18px; border: none; background: none; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; }
        .view-tab:hover { color: var(--text); }
        .view-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
        .view-tab .material-icons-round { font-size: 18px; }
        .view-tab-actions { margin-left: auto; display: flex; align-items: center; gap: 6px; padding: 4px 0; }
        .toggle-label { display: inline-flex; align-items: center; gap: 2px; cursor: pointer; padding: 4px 6px; border-radius: 8px; color: var(--text-secondary); transition: all 0.2s; font-size: 0.8rem; }
        .toggle-label:hover { color: var(--text); background: var(--surface); }
        .toggle-label input { display: none; }
        .toggle-label:has(input:checked) { color: var(--accent); background: rgba(0,122,204,0.1); }
        .toggle-label .material-icons-round { font-size: 18px; }

        /* Main workspace: terminal + sidebar side by side */
        .main-workspace { display: flex; border: 1px solid var(--border); border-top: none; border-radius: 0 0 16px 16px; overflow: hidden; background: var(--surface); height: 660px; min-height: 660px; }

        /* Views */
        .views-container { flex: 1; display: flex; flex-direction: column; min-width: 0; overflow: hidden; }
        .terminal-panel { position: relative; display: flex; flex-direction: column; flex: 1; overflow: hidden; background: var(--bg); }
        #terminal-container { width: 100%; height: 100%; padding: 4px 0 4px 8px; box-sizing: border-box; overflow: hidden; }
        .xterm-viewport { overscroll-behavior: contain !important; }
        .xterm-viewport::-webkit-scrollbar { width: 12px; height: 12px; background: transparent; }
        .xterm-viewport::-webkit-scrollbar-track { background: var(--bg); border-left: 1px solid var(--border); }
        .xterm-viewport::-webkit-scrollbar-thumb { background: rgba(128, 128, 128, 0.4); border: 2px solid var(--bg); border-radius: 6px; }
        .xterm-viewport::-webkit-scrollbar-thumb:hover { background: rgba(128, 128, 128, 0.7); }
        .views-container.split-view .terminal-panel { flex: 1; min-width: 0; }
        .terminal-resize-handle { height: 6px; background: var(--border); cursor: ns-resize; flex-shrink: 0; transition: background 0.2s; display: flex; align-items: center; justify-content: center; }
        .terminal-resize-handle::after { content: ''; width: 40px; height: 2px; background: var(--text-secondary); border-radius: 2px; opacity: 0.4; }
        .terminal-resize-handle:hover, .terminal-resize-handle.dragging { background: var(--accent); }
        .terminal-resize-handle:hover::after, .terminal-resize-handle.dragging::after { background: #fff; opacity: 0.8; }
        .chart-panel { flex: 1; min-height: 420px; display: flex; flex-direction: column; padding: 10px; background: var(--bg); }
        
