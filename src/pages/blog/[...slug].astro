---
// src/pages/blog/[...slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Comments from '../../components/Comments.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} | OKay's Blog`} description={post.data.description}>
  <a href="/" class="back-btn-fixed">
    <span class="material-icons-round">arrow_back</span> 返回
  </a>

  <article class="blog-post article-detail">

    <header class="post-header article-header">
      {post.data.cover && (
        <div class="cover-wrapper">
          <img src={post.data.cover} alt={post.data.title} class="article-cover" />
        </div>
      )}
      <div class="meta article-meta-top">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="divider">·</span>
        <div class="tags">
          {post.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
      <h1>{post.data.title}</h1>
    </header>

    <div class="content markdown-body">
      <Content />
    </div>

    <Comments />
  </article>
</Layout>

<style>
  .blog-post {
    max-width: 760px;
    margin: 0 auto;
    padding-top: 2rem;
    animation: fadeIn 0.5s ease-out forwards;
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .divider {
    color: var(--border-color);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--link-color);
  }

  .post-header h1 {
    font-size: 2.5rem;
    line-height: 1.3;
    margin: 0;
    color: var(--text-color);
  }

  .content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .back-btn-fixed {
    position: fixed;
    top: 90px;
    left: max(24px, calc(50vw - 600px + 24px));
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    color: var(--text);
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    padding: 8px 18px;
    transition: all 0.25s ease;
    z-index: 100;
  }

  .back-btn-fixed:hover {
    background: var(--surface);
    border-color: var(--accent);
    color: var(--text);
    transform: translateX(-2px);
    box-shadow: var(--shadow-sm);
  }

  .cover-wrapper {
    width: 100%;
    margin-bottom: 2rem;
  }

  .article-cover {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    display: block;
  }

  /* Markdown body styles to mimic standard readable formats */
  :global(.markdown-body h2) {
    font-size: 1.75rem;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  :global(.markdown-body h3) {
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  :global(.markdown-body p) {
    margin-bottom: 1.5rem;
  }

  :global(.markdown-body img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
    border: 1px solid var(--border-color);
  }

  :global(.markdown-body code:not(pre code)) {
    background-color: var(--border-color);
    color: var(--text-color);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  :global(.markdown-body pre) {
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--border-color);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  :global(.markdown-body pre code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  :global(.markdown-body blockquote) {
    border-left: 4px solid var(--link-color);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    background-color: var(--card-bg);
    padding: 1rem;
    border-radius: 0 8px 8px 0;
  }

  :global(.markdown-body ul), :global(.markdown-body ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  :global(.markdown-body li) {
    margin-bottom: 0.5rem;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
