---
import Layout from '../layouts/Layout.astro';

const modelGroups = [
    {
        title: 'PCB',
        models: [
            {
                src: '/models/IMX415.glb',
                title: 'IMX415',
                name: 'IMX415',
                desc: '基于 IMX415 图像传感器的 PCB / 模组 3D 展示，用来呈现器件布局、接口结构与整体硬件设计细节。',
                icon: 'developer_board',
                iconColor: '#0b57d0',
                tag: 'PCB 作品',
                tagStyle: 'background: rgba(11, 87, 208, 0.12); color: #0b57d0;'
            },
            {
                src: '/models/OS08A20.glb',
                title: 'OS08A20',
                name: 'OS08A20',
                desc: '基于 OS08A20 图像传感器的 PCB / 模组 3D 展示，用来呈现传感器布局、接口设计与硬件结构细节。',
                icon: 'developer_board',
                iconColor: '#1a73e8',
                tag: 'PCB 作品',
                tagStyle: 'background: rgba(26, 115, 232, 0.12); color: #1a73e8;'
            }
        ]
    },
    {
        title: 'Toy',
        models: [
            {
                src: '/models/pocket3.glb',
                title: 'DJI Pocket 3',
                name: 'Pocket 3',
                desc: '大疆口袋云台相机，1 英寸 CMOS 传感器，4K/120fps 录制，三轴机械增稳，轻巧便携的 Vlog 神器。',
                icon: 'videocam',
                iconColor: '#ea4335',
                tag: '摄影设备',
                tagStyle: 'background: rgba(234, 67, 53, 0.1); color: #ea4335;'
            },
            {
                src: '/models/cat.glb',
                title: 'Pad Pad',
                name: 'Pad Pad',
                desc: '中国原产家猫品种，虎斑纹理，性格独立机敏，身手矫健，是最受欢迎的本土猫咪之一。',
                icon: 'pets',
                iconColor: '#ff9800',
                tag: '萌宠伙伴',
                tagStyle: 'background: rgba(255, 152, 0, 0.1); color: #ff9800;'
            },
            {
                src: '/models/xiaomisu7.glb',
                title: 'Xiaomi Su7',
                name: 'Xiaomi Su7',
                desc: '小米首款纯电轿车，零百加速 2.78 秒，流线型车身设计，搭载澎湃智能座舱与高阶智驾系统。',
                icon: 'directions_car',
                iconColor: '#ff6d00',
                tag: '智能汽车',
                tagStyle: 'background: rgba(255, 109, 0, 0.1); color: #ff6d00;'
            },
            {
                src: '/models/lexusLFA.glb',
                title: 'Lexus LFA',
                name: 'Lexus LFA',
                desc: '雷克萨斯传奇超跑，4.8L V10 自然吸气引擎，560 匹马力，全球限量 500 台，日系性能巅峰之作。',
                icon: 'sports_score',
                iconColor: '#1a237e',
                tag: '经典超跑',
                tagStyle: 'background: rgba(26, 35, 126, 0.1); color: #1a237e;'
            },
            {
                src: '/models/Gundam.glb',
                title: 'Gundam',
                name: 'Gundam',
                desc: '经典日系机甲，精密机械结构与装甲设计的完美融合，承载着一代人的热血与梦想。',
                icon: 'smart_toy',
                iconColor: '#7c4dff',
                tag: '机甲模型',
                tagStyle: 'background: rgba(124, 77, 255, 0.1); color: #7c4dff;'
            },
            {
                src: '/models/sonnyWH-1000-XM5.glb',
                title: 'Sonny🎧',
                name: 'Sonny🎧',
                desc: '索尼 WH-1000XM5 无线降噪耳机，提供沉浸式的无损音质与顶级的静谧体验。',
                icon: 'headphones',
                iconColor: '#e91e63',
                tag: '音频设备',
                tagStyle: 'background: rgba(233, 30, 99, 0.1); color: #e91e63;'
            }
        ]
    }
];

const initialModel = modelGroups[0].models[0];
---

<Layout title="3D 展厅 | OKay's Blog">
    <!-- Import Google's model-viewer component from Cloudflare CDN for global speed -->
    <script type="module" src="https://cdnjs.cloudflare.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>

    <main class="works-main">
        <header class="works-header">
            <a href="/" class="back-link">
                <span class="material-icons-round">arrow_back</span> 返回主页
            </a>
            <h1 class="works-title">
                <span class="material-icons-round">view_in_ar</span> 作品展厅
            </h1>
            <p class="works-subtitle">拖拽旋转，滚轮缩放，沉浸式探索我的 PCB 设计与 Toy 模型收藏</p>
        </header>

        <section class="showroom-container">
            <!-- 左侧模型选择列表 -->
            <div class="model-list">
                {modelGroups.map((group) => (
                    <section class="model-group">
                        <h3 class="list-heading">{group.title}</h3>
                        {group.models.map((model) => (
                            <button
                                class={`model-btn${model.src === initialModel.src ? ' active' : ''}`}
                                data-src={model.src}
                                data-title={model.title}
                                data-desc={model.desc}
                                data-alt={`3D 模型展示 - ${model.title}`}
                            >
                                <div class="model-icon">
                                    <span class="material-icons-round" style={`color: ${model.iconColor};`}>{model.icon}</span>
                                </div>
                                <div class="model-info">
                                    <span class="model-name">{model.name}</span>
                                    <span class="model-tag highlight" style={model.tagStyle}>{model.tag}</span>
                                </div>
                            </button>
                        ))}
                    </section>
                ))}
            </div>

            <!-- 右侧 3D 互动展示区 -->
            <div class="viewer-wrapper">
                <model-viewer 
                    id="main-viewer"
                    src={initialModel.src}
                    alt={`3D 模型展示 - ${initialModel.title}`}
                    camera-controls 
                    auto-rotate
                    autoplay
                    animation-crossfade-duration="0.5"
                    rotation-per-second="30deg"
                    shadow-intensity="1.5"
                    exposure="1"
                    environment-image="neutral"
                    class="glass-viewer"
                >
                    <!-- 自定义加载进度条 -->
                    <div class="progress-bar hide" slot="progress-bar">
                        <div class="update-bar"></div>
                    </div>
                    
                    <!-- 提示文字 -->
                    <div id="ar-prompt">
                        <span class="material-icons-round">touch_app</span> 交互体验
                    </div>
                </model-viewer>

                <!-- 模型信息卡片浮层 -->
                <div class="model-details-card glass-panel">
                    <h2 id="overlay-title">{initialModel.title}</h2>
                    <p id="overlay-desc">{initialModel.desc}</p>
                </div>
            </div>
        </section>
    </main>

    <style>
        .works-main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 120px 20px 60px; /* 留出顶部 Header 空间 */
            min-height: calc(100vh - 150px);
            animation: fadeIn 0.8s ease-out;
        }

        .works-header {
            text-align: center;
            margin-bottom: 40px;
            position: relative;
        }

        .back-link {
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
            padding: 8px 16px;
            border-radius: 8px;
            background: var(--surface);
            border: 1px solid var(--border);
            transition: all 0.2s;
        }

        .back-link:hover {
            background: var(--bg-secondary);
            color: var(--text);
            transform: translateY(-50%) translateX(-4px);
        }

        .works-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: linear-gradient(135deg, var(--text) 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .works-title .material-icons-round {
            font-size: 2.5rem;
            color: var(--accent);
            -webkit-text-fill-color: initial;
        }

        .works-subtitle {
            font-size: 1.1rem;
            color: var(--text-secondary);
        }

        .showroom-container {
            display: flex;
            gap: 24px;
            height: 600px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
        }

        /* 深色模式下的阴影 */
        [data-theme='dark'] .showroom-container {
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            background: rgba(30, 30, 35, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        /* 左侧列表 */
        .model-list {
            flex: 0 0 300px;
            display: flex;
            flex-direction: column;
            gap: 18px;
            overflow-y: auto;
            padding-right: 10px;
        }

        .model-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .model-group + .model-group {
            padding-top: 4px;
            border-top: 1px solid var(--border);
        }

        /* 自定义滚动条 */
        .model-list::-webkit-scrollbar {
            width: 6px;
        }
        .model-list::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }

        .list-heading {
            font-size: 1.2rem;
            font-weight: 700;
            margin: 0;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }

        .model-btn {
            display: flex;
            align-items: center;
            gap: 16px;
            background: transparent;
            border: 1px solid transparent;
            padding: 16px;
            border-radius: 12px;
            cursor: pointer;
            text-align: left;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .model-btn:hover {
            background: var(--bg-secondary);
            transform: translateX(4px);
        }

        .model-btn.active {
            background: var(--surface);
            border: 1px solid var(--accent);
            box-shadow: 0 4px 12px rgba(0, 152, 255, 0.15);
        }

        .model-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            background: var(--bg);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            transition: 0.3s;
        }

        .model-btn.active .model-icon {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        .model-info {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .model-name {
            font-weight: 600;
            color: var(--text);
            font-size: 1rem;
        }

        .model-tag {
            font-size: 0.75rem;
            color: var(--text-secondary);
            background: var(--bg);
            padding: 2px 8px;
            border-radius: 4px;
            width: fit-content;
        }

        .model-tag.highlight {
            color: var(--accent);
            background: rgba(0, 152, 255, 0.1);
        }

        /* 右侧 3D 区域 */
        .viewer-wrapper {
            flex: 1;
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            background: var(--bg-secondary);
        }

        .glass-viewer {
            width: 100%;
            height: 100%;
            --poster-color: transparent;
            background-color: transparent;
        }

        /* 模型加载进度条 */
        .progress-bar {
            display: block;
            width: 33%;
            height: 10%;
            max-height: 4px;
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate3d(-50%, -50%, 0);
            border-radius: 4px;
            box-shadow: 0px 3px 10px rgba(0, 0, 0, 0.2);
            background-color: var(--border);
            transition: visibility 0.3s;
        }

        .progress-bar.hide {
            visibility: hidden;
            transition: visibility 0.3s;
        }

        .update-bar {
            background-color: var(--accent);
            width: 0%;
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s;
        }

        #ar-prompt {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.5);
            color: #fff;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 6px;
            backdrop-filter: blur(4px);
            pointer-events: none;
            animation: pulse 2s infinite;
        }

        /* 信息卡片 */
        .model-details-card {
            position: absolute;
            bottom: 24px;
            left: 24px;
            right: 24px;
            padding: 24px;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transform: translateY(0);
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s;
        }

        [data-theme='dark'] .model-details-card {
            background: rgba(30, 30, 35, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            color: var(--text);
        }

        .model-details-card h2 {
            margin: 0 0 8px 0;
            font-size: 1.4rem;
            font-weight: 700;
        }

        .model-details-card p {
            margin: 0;
            color: var(--text-secondary);
            line-height: 1.6;
            font-size: 0.95rem;
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.05); opacity: 1; }
            100% { transform: scale(1); opacity: 0.8; }
        }

        /* 修改卡片切换时的动画类 */
        .card-animating {
            transform: translateY(20px);
            opacity: 0;
        }

        /* 响应式调整 */
        @media (max-width: 800px) {
            .showroom-container {
                flex-direction: column;
                height: auto;
                min-height: 800px;
            }
            .model-list {
                flex: none;
                max-height: 260px;
                overflow-y: auto;
                overflow-x: hidden;
                padding-right: 4px;
            }
            .viewer-wrapper {
                height: 500px;
            }
        }
    </style>

    <script is:inline>
        function setupShowroom() {
            const viewer = document.querySelector('#main-viewer');
            const btns = document.querySelectorAll('.model-btn');
            const titleEl = document.getElementById('overlay-title');
            const descEl = document.getElementById('overlay-desc');
            const cardEl = document.querySelector('.model-details-card');
            const showroom = document.querySelector('.showroom-container');

            if (!viewer || btns.length === 0 || !showroom) return;
            if (showroom.getAttribute('data-showroom-bound') === 'true') return;
            showroom.setAttribute('data-showroom-bound', 'true');

            // 进度条逻辑
            viewer.addEventListener('progress', (event) => {
                const progressBar = event.target.querySelector('.progress-bar');
                const updateBar = event.target.querySelector('.update-bar');
                if (!progressBar || !updateBar) return;
                
                updateBar.style.width = `${event.detail.totalProgress * 100}%`;
                if (event.detail.totalProgress === 1) {
                    progressBar.classList.add('hide');
                } else {
                    progressBar.classList.remove('hide');
                    if (event.detail.totalProgress === 0) {
                        updateBar.style.width = '0%';
                    }
                }
            });

            // 切换模型加载逻辑
            btns.forEach(btn => {
                btn.addEventListener('click', function() {
                    // Update active state
                    btns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    // Data
                    const src = btn.getAttribute('data-src');
                    const title = btn.getAttribute('data-title');
                    const desc = btn.getAttribute('data-desc');
                    const alt = btn.getAttribute('data-alt');

                    if (cardEl) cardEl.classList.add('card-animating');
                    
                    // Switch model source
                    viewer.src = src;
                    if (alt) viewer.alt = alt;

                    // Re-enable auto-rotate if user stopped it by interacting previously
                    viewer.autoRotate = true;

                    // Update Text after animation out
                    setTimeout(() => {
                        if (titleEl) titleEl.textContent = title;
                        if (descEl) descEl.textContent = desc;
                        // Animate card in
                        if (cardEl) cardEl.classList.remove('card-animating');
                    }, 300);
                });
            });
            
            // Interaction disables auto-rotate to let user explore
            viewer.addEventListener('mousedown', () => viewer.autoRotate = false);
            viewer.addEventListener('touchstart', () => viewer.autoRotate = false);
        }

        document.addEventListener('astro:page-load', setupShowroom);
    </script>
</Layout>
