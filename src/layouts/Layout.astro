---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import AIAssistant from '../components/AIAssistant.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "嵌入式 Linux · AI · 硬件开发" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ViewTransitions />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			document.documentElement.setAttribute('data-theme', theme);
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body>
		<!-- Welcome Screen (Splash Animation) -->
		<div id="welcome-screen" class="welcome-screen">
			<div class="welcome-inner">
				<div class="welcome-logo-anim">
					<span class="welcome-letter" style="--i:0">O</span>
					<span class="welcome-letter" style="--i:1">K</span>
					<span class="welcome-letter" style="--i:2">a</span>
					<span class="welcome-letter" style="--i:3">y</span>
					<span class="welcome-letter dot" style="--i:4">'</span>
					<span class="welcome-letter" style="--i:5">s</span>
					<span class="welcome-letter space" style="--i:6">&nbsp;</span>
					<span class="welcome-letter" style="--i:7">B</span>
					<span class="welcome-letter" style="--i:8">l</span>
					<span class="welcome-letter" style="--i:9">o</span>
					<span class="welcome-letter" style="--i:10">g</span>
				</div>
				<p class="welcome-subtitle">嵌入式 Linux · AI · 硬件开发</p>
				<div class="welcome-loader">
					<div class="welcome-bar"></div>
				</div>
			</div>
		</div>

		<div id="app" class="app" style="opacity: 0; transition: opacity 0.5s ease;">
			<Header />
			
			<slot />

			<Footer />
			
			<MusicPlayer />
			<AIAssistant />
		</div>

		<script is:inline>
			(() => {
				const hasPlayed = sessionStorage.getItem('hasPlayedWelcome');
				const isRoot = window.location.pathname === '/' || window.location.pathname === '/index.html';
				
				// Play if they haven't seen it this session and are hitting the root page
				const shouldPlayAnimation = !hasPlayed && isRoot;

				const welcome = document.getElementById('welcome-screen');
				const app = document.getElementById('app');

				if (!shouldPlayAnimation) {
					if(welcome) welcome.style.display = 'none';
					if(app) {
						app.style.opacity = '1';
						app.style.visibility = 'visible';
					}
				} else {
					sessionStorage.setItem('hasPlayedWelcome', 'true');
					if(app) {
						app.style.opacity = '0';
						app.classList.remove('hidden');
					}
					if(welcome) {
						welcome.style.display = 'flex';
						welcome.classList.remove('fade-out');
					}

					const startAnim = () => {
						setTimeout(() => {
							const w = document.getElementById('welcome-screen');
							const a = document.getElementById('app');
							if(w) w.classList.add('fade-out');
							if(a) a.style.opacity = '1';
							setTimeout(() => {
								if(w) w.style.display = 'none';
							}, 600);
						}, 2500);
					};

					if (document.readyState === 'complete') {
						startAnim();
					} else {
						window.addEventListener('load', startAnim);
					}
				}

				// Keep track if we are in the middle of the initial splash animation
				let isInitialSplash = shouldPlayAnimation;

				// Handle subsequent Astro SPA navigations instantly
				document.addEventListener('astro:page-load', () => {
					if (isInitialSplash) {
						isInitialSplash = false; // Only allow skipping on actual navigations
						return;
					}

					const w = document.getElementById('welcome-screen');
					const a = document.getElementById('app');
					if (w) w.style.display = 'none';
					if (a) {
						a.style.opacity = '1';
						a.style.visibility = 'visible';
					}
				});
			})();
		</script>
	<!-- Developer Mode Hidden Trigger & Modal -->
		<div id="dev-trigger-area" style="position: fixed; bottom: 0; right: 0; width: 50px; height: 50px; z-index: 9999; cursor: default;"></div>
		
		<div id="dev-auth-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.8); z-index: 10000; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
			<div style="background: var(--surface); padding: 30px; border-radius: 16px; width: 320px; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.5); border: 1px solid var(--border);">
				<h3 style="margin-bottom: 20px; font-size: 1.2rem;">开发者模式</h3>
				<input type="text" id="dev-username" placeholder="用户名" style="width: 100%; padding: 10px; margin-bottom: 15px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); outline: none;">
				<input type="password" id="dev-password" placeholder="密码" style="width: 100%; padding: 10px; margin-bottom: 20px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); outline: none;">
				<div style="display: flex; gap: 10px;">
					<button id="dev-cancel-btn" style="flex: 1; padding: 10px; background: var(--bg-secondary); border: none; border-radius: 8px; color: var(--text); cursor: pointer; font-weight: 600;">取消</button>
					<button id="dev-login-btn" style="flex: 1; padding: 10px; background: var(--accent); border: none; border-radius: 8px; color: #fff; cursor: pointer; font-weight: 600;">进入</button>
				</div>
				<p id="dev-error-msg" style="color: #ff3a3a; font-size: 0.85rem; margin-top: 15px; display: none;">用户名或密码错误</p>
			</div>
		</div>

		<script is:inline>
			// Developer Mode Authentication Logic
			const triggerArea = document.getElementById('dev-trigger-area');
			const authModal = document.getElementById('dev-auth-modal');
			const cancelBtn = document.getElementById('dev-cancel-btn');
			const loginBtn = document.getElementById('dev-login-btn');
			const userInp = document.getElementById('dev-username');
			const passInp = document.getElementById('dev-password');
			const errorMsg = document.getElementById('dev-error-msg');
			
			let clickCount = 0;
			let clickTimer = null;

			// Check current state
			const isDevMode = localStorage.getItem('okay_dev_mode') === 'true';
			if (isDevMode) {
				document.body.classList.add('dev-mode-active');
			}

			if (triggerArea) {
				triggerArea.addEventListener('click', () => {
					// Dev mode only works on localhost
					if (!['localhost', '127.0.0.1'].includes(window.location.hostname)) return;
					clickCount++;
					if (clickTimer) clearTimeout(clickTimer);
					
					if (clickCount >= 5) {
						clickCount = 0;
						if (authModal && !document.body.classList.contains('dev-mode-active')) {
							authModal.style.display = 'flex';
							errorMsg.style.display = 'none';
							userInp.value = '';
							passInp.value = '';
							userInp.focus();
						}
					} else {
						clickTimer = setTimeout(() => {
							clickCount = 0;
						}, 1000);
					}
				});
			}

			if (cancelBtn) {
				cancelBtn.addEventListener('click', () => {
					authModal.style.display = 'none';
				});
			}

			if (loginBtn) {
				const attemptLogin = () => {
					const u = userInp.value.trim();
					const p = passInp.value.trim();
					if (u === 'OKay' && p === 'Jhh20040314') {
						localStorage.setItem('okay_dev_mode', 'true');
						document.body.classList.add('dev-mode-active');
						authModal.style.display = 'none';
						// Dispatch event so other components (Header) can react
						window.dispatchEvent(new Event('dev-mode-changed'));
					} else {
						errorMsg.style.display = 'block';
					}
				};
				loginBtn.addEventListener('click', attemptLogin);
				passInp.addEventListener('keypress', (e) => {
					if (e.key === 'Enter') attemptLogin();
				});
			}
		</script>
	</body>
</html>
