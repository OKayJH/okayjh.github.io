// === Terminal & Chart Init ===
function initTerminal(s) {
    if (s.term) return;
    if (typeof Terminal === 'undefined' || typeof FitAddon === 'undefined') { setTimeout(function () { initTerminal(s); }, 200); return; }
    try {
        function getTermTheme() {
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            return isDark
                ? { background: '#1a1b2e', foreground: '#e2e8f0', cursor: '#7c3aed', selectionBackground: '#334155' }
                : { background: '#1e1e2e', foreground: '#cdd6f4', cursor: '#007acc', selectionBackground: '#45475a' };
        }
        s.term = new Terminal({ cursorBlink: true, fontSize: 14, fontFamily: "'JetBrains Mono','Fira Code','Cascadia Code',monospace", theme: getTermTheme(), scrollback: 10000, convertEol: true });
        s.fitAddon = new FitAddon.FitAddon();
        s.term.loadAddon(s.fitAddon);
        if (typeof WebLinksAddon !== 'undefined') s.term.loadAddon(new WebLinksAddon.WebLinksAddon());
        s.term.open(s.container);

        // Prevent wheel scroll chaining to page when terminal is already at top/bottom.
        // This keeps page scroll unaffected only when pointer leaves terminal area.
        if (!s._wheelBoundaryLockBound) {
            s._wheelBoundaryLockBound = true;
            s.container.addEventListener('wheel', function (e) {
                var viewport = s.container.querySelector('.xterm-viewport');
                if (!viewport) return;

                var deltaY = e.deltaY || 0;
                if (deltaY === 0) return;

                var maxScrollTop = Math.max(0, viewport.scrollHeight - viewport.clientHeight);
                var current = viewport.scrollTop;
                var atTop = current <= 0;
                var atBottom = current >= maxScrollTop - 1;

                if ((deltaY < 0 && atTop) || (deltaY > 0 && atBottom)) {
                    e.preventDefault();
                    e.stopPropagation();
                }
            }, { passive: false });
        }

        setTimeout(function () { s.fitAddon.fit(); }, 50);
        new ResizeObserver(function () { try { s.fitAddon.fit(); } catch (e) { } }).observe(s.container);

        s.term.writeln('\x1b[1;36m\u2554' + '\u2550'.repeat(48) + '\u2557\x1b[0m');
        s.term.writeln('\x1b[1;36m\u2551\x1b[0m   \x1b[1;33mOKay Terminal [' + s.name + ']\x1b[0m                      \x1b[1;36m\u2551\x1b[0m');
        s.term.writeln('\x1b[1;36m\u2551\x1b[0m                                                \x1b[1;36m\u2551\x1b[0m');
        s.term.writeln('\x1b[1;36m\u2551\x1b[0m   \x1b[0;36m交互模式\x1b[0m \u2500 标准终端数据交互流通信              \x1b[1;36m\u2551\x1b[0m');
        s.term.writeln('\x1b[1;36m\u2551\x1b[0m   \x1b[0;35m监控模式\x1b[0m \u2500 独立接收视图与快捷指令分发          \x1b[1;36m\u2551\x1b[0m');
        s.term.writeln('\x1b[1;36m\u2551\x1b[0m                                                \x1b[1;36m\u2551\x1b[0m');
        s.term.writeln('\x1b[1;36m\u2551\x1b[0m   \u70b9\u51fb \x1b[1;32m\u9009\u62e9\u7aef\u53e3\x1b[0m \u5f00\u59cb\u4f7f\u7528                    \x1b[1;36m\u2551\x1b[0m');
        s.term.writeln('\x1b[1;36m\u255a' + '\u2550'.repeat(48) + '\u255d\x1b[0m');
        s.term.writeln('');

        s.term.onData(function (data) {
            if (!s.isConnected || !s.writer) return;
            if (!s.interactiveMode) return;
            var bytes = new TextEncoder().encode(data);
            s.writer.write(bytes);
            s.txCount += bytes.length;
            if (activeSession === s) txCountEl.textContent = s.txCount.toString();
            if (s.localEcho) s.term.write(data);
        });

        s.container.addEventListener('contextmenu', function (e) {
            e.preventDefault();
            if (!s.isConnected || !s.writer || !s.interactiveMode) return;
            navigator.clipboard.readText().then(function (text) {
                if (text) {
                    var safeText = text.replace(/\r\n|\n|\r/g, '');
                    if (safeText) {
                        var bytes = new TextEncoder().encode(safeText);
                        s.writer.write(bytes);
                        s.txCount += bytes.length;
                        if (activeSession === s) txCountEl.textContent = s.txCount.toString();
                        if (s.localEcho) s.term.write(safeText);
                        showToast('已粘贴到终端 ' + s.name, 'ok');
                    }
                }
            }).catch(function (err) {
                console.error('Paste failed', err);
            });
        });

        new MutationObserver(function () {
            if (s.term) s.term.options.theme = getTermTheme();
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    } catch (e) { console.error('Terminal init failed:', e); }
}

function initChartJS() {
    if (chart) return;
    if (typeof Chart === 'undefined') { setTimeout(initChartJS, 200); return; }
    try {
        chart = new Chart(document.getElementById('waveform-chart'), {
            type: 'line',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false, animation: false,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { position: 'top', labels: { color: getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#666', font: { size: 11 } } } },
                scales: {
                    x: { display: true, ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#999', maxTicksLimit: 10 }, grid: { color: 'rgba(128,128,128,0.15)' } },
                    y: { display: true, ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#999' }, grid: { color: 'rgba(128,128,128,0.15)' } }
                }
            }
        });
        new MutationObserver(function () {
            if (chart) {
                var tc2 = getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#666';
                var sc = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#999';
                chart.options.plugins.legend.labels.color = tc2;
                chart.options.scales.x.ticks.color = sc;
                chart.options.scales.y.ticks.color = sc;
                chart.update('none');
            }
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    } catch (e) { console.error('Chart init failed:', e); }
}

// === Guards, Resizers & Commands Library ===
window.addEventListener('beforeunload', function (e) {
    var connCount = sessions.filter(function (s) { return s.isConnected; }).length;
    if (connCount > 0) {
        var msg = '\u6709 ' + connCount + ' \u4e2a\u4e32\u53e3\u4ecd\u5904\u4e8e\u8fde\u63a5\u72b6\u6001\uff0c\u786e\u5b9a\u8981\u79bb\u5f00\u5417\uff1f';
        e.returnValue = msg;
        return msg;
    }
});
document.querySelector('.back-link').addEventListener('click', function (e) {
    var connCount = sessions.filter(function (s) { return s.isConnected; }).length;
    if (connCount > 0) {
        e.preventDefault();
        if (confirm('\u6709 ' + connCount + ' \u4e2a\u4e32\u53e3\u5f53\u524d\u5904\u4e8e\u8fde\u63a5\u72b6\u6001\u3002\n\n\u70b9\u51fb\u3010\u786e\u5b9a\u3011\u5c06\u65ad\u5f00\u6240\u6709\u8fde\u63a5\u5e76\u8fd4\u56de\u4e3b\u9875\u3002\n\u70b9\u51fb\u3010\u53d6\u6d88\u3011\u4fdd\u7559\u5728\u5f53\u524d\u9875\u9762\u3002')) {
            Promise.all(sessions.map(function (s) { return cleanupConnection(s); })).then(function () {
                window.location.href = '/';
            });
        }
    }
});

(function () {
    var handle = document.getElementById('terminal-resize-handle');
    var tc = document.getElementById('terminals-wrapper');
    var workspace = document.querySelector('.main-workspace');
    if (!handle || !tc || !workspace) return;
    var startY = 0, startH = 0, dragging = false;
    function onDown(e) {
        e.preventDefault();
        dragging = true;
        startY = e.touches ? e.touches[0].clientY : e.clientY;
        startH = workspace.offsetHeight;
        handle.classList.add('dragging');
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
        document.addEventListener('touchmove', onMove, { passive: false });
        document.addEventListener('touchend', onUp);
    }
    function onMove(e) {
        if (!dragging) return;
        var y = e.touches ? e.touches[0].clientY : e.clientY;
        var newH = Math.max(660, startH + (y - startY));
        workspace.style.height = newH + 'px';
        sessions.forEach(function (s) { if (s.fitAddon) try { s.fitAddon.fit(); } catch (ex) { } });
    }
    function onUp() {
        dragging = false;
        handle.classList.remove('dragging');
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        document.removeEventListener('touchmove', onMove);
        document.removeEventListener('touchend', onUp);
        sessions.forEach(function (s) { if (s.fitAddon) try { s.fitAddon.fit(); } catch (ex) { } });
    }
    handle.addEventListener('mousedown', onDown);
    handle.addEventListener('touchstart', onDown);
})();

(function () {
    var handle = document.getElementById('sidebar-resize-handle');
    var sidebar = document.getElementById('primary-sidebar');
    if (!handle || !sidebar) return;
    var startX = 0, startW = 0, dragging = false;
    function onDown(e) {
        if (sidebar.classList.contains('collapsed')) return;
        e.preventDefault();
        dragging = true;
        startX = e.touches ? e.touches[0].clientX : e.clientX;
        startW = sidebar.offsetWidth;
        handle.classList.add('dragging');
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
        document.addEventListener('touchmove', onMove, { passive: false });
        document.addEventListener('touchend', onUp);
    }
    function onMove(e) {
        if (!dragging) return;
        var x = e.touches ? e.touches[0].clientX : e.clientX;
        var newW = Math.max(150, Math.min(500, startW + (x - startX)));
        sidebar.style.width = newW + 'px';
        sessions.forEach(function (s) { if (s.fitAddon) try { s.fitAddon.fit(); } catch (ex) { } });
    }
    function onUp() {
        dragging = false;
        handle.classList.remove('dragging');
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        document.removeEventListener('touchmove', onMove);
        document.removeEventListener('touchend', onUp);
        sessions.forEach(function (s) { if (s.fitAddon) try { s.fitAddon.fit(); } catch (ex) { } });
    }
    handle.addEventListener('mousedown', onDown);
    handle.addEventListener('touchstart', onDown);
})();

(function () {
    var STORAGE_KEY = 'serialDebug_shellCmds_v2';
    var defaultCmds = [
        { cat: '系统信息', cmd: 'uname -a', desc: '内核信息' },
        { cat: '系统信息', cmd: 'cat /etc/os-release', desc: '发行版信息' },
        { cat: '系统信息', cmd: 'cat /proc/cpuinfo', desc: 'CPU 详情' },
        { cat: '系统信息', cmd: 'cat /proc/device-tree/model', desc: '设备型号' },
        { cat: '系统信息', cmd: 'free -m', desc: '内存使用' },
        { cat: '系统信息', cmd: 'df -h', desc: '磁盘使用' },
        { cat: '系统信息', cmd: 'uptime', desc: '运行时间' },
        { cat: '文件操作', cmd: 'ls -la', desc: '详细列表' },
        { cat: '文件操作', cmd: 'pwd', desc: '当前目录' },
        { cat: '文件操作', cmd: 'du -sh *', desc: '目录大小' },
        { cat: '文件操作', cmd: 'mount | column -t', desc: '查看挂载' },
        { cat: '网络工具', cmd: 'ifconfig', desc: '网卡信息' },
        { cat: '网络工具', cmd: 'ip addr', desc: 'IP 地址' },
        { cat: '网络工具', cmd: 'ping -c 4 114.114.114.114', desc: '外网连通' },
        { cat: '网络工具', cmd: 'netstat -tulnp', desc: '监听端口' },
        { cat: '进程管理', cmd: 'ps aux', desc: '进程列表' },
        { cat: '进程管理', cmd: 'top -n 1 -b', desc: 'CPU快照' },
        { cat: '进程管理', cmd: 'htop', desc: '高级管理' },
        { cat: '外设硬件', cmd: 'lsusb', desc: 'USB 设备' },
        { cat: '外设硬件', cmd: 'lsmod', desc: '内核模块' },
        { cat: '外设硬件', cmd: 'i2cdetect -y -r 1', desc: 'I2C扫描(总线1)' },
        { cat: '系统调优', cmd: 'dmesg | tail -30', desc: '最新内核日志' },
        { cat: '系统调优', cmd: 'dmesg | grep -i err', desc: '内核错误过滤' }
    ];
    function loadCmds() { try { var d = localStorage.getItem(STORAGE_KEY); return d ? JSON.parse(d) : null; } catch (e) { return null; } }
    function saveCmds(cmds) { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(cmds)); } catch (e) { } }
    var cmds = loadCmds();
    if (!cmds) { cmds = defaultCmds.slice(); saveCmds(cmds); }

    var countEl = document.getElementById('shell-cmds-count');
    var listEl = document.getElementById('shell-cmds-list');
    var addBtn = document.getElementById('btn-add-shell-cmd');
    var cmdInput = document.getElementById('shell-cmd-input');
    var descInput = document.getElementById('shell-cmd-desc');
    var catSelect = document.getElementById('shell-cmd-category');

    function renderCmds() {
        countEl.textContent = cmds.length;
        listEl.innerHTML = '';
        var groups = {};
        cmds.forEach(function (c, i) {
            if (!groups[c.cat]) groups[c.cat] = [];
            groups[c.cat].push({ idx: i, cmd: c.cmd, desc: c.desc });
        });
        var catOrder = ['系统信息', '文件操作', '网络相关', '进程管理', '外设硬件', '高级调试', '自定义'];
        Object.keys(groups).sort(function (a, b) {
            var ai = catOrder.indexOf(a), bi = catOrder.indexOf(b);
            return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
        }).forEach(function (cat) {
            var g = document.createElement('div');
            g.className = 'shell-cat-group';
            var titleHtml = '<div class="shell-cat-title">' + cat + '</div>';
            var tableObj = document.createElement('div');
            tableObj.className = 'shell-cmd-table';
            groups[cat].forEach(function (item) {
                var row = document.createElement('div');
                row.className = 'shell-cmd-item';
                var divHtml = document.createElement('div'); divHtml.textContent = item.cmd; var escCmd = divHtml.innerHTML;
                divHtml.textContent = item.desc || ''; var escDesc = divHtml.innerHTML;
                row.innerHTML =
                    '<div class="shell-cmd-text" title="' + escCmd + '">' + escCmd + '</div>' +
                    '<div class="shell-cmd-desc" title="' + escDesc + '">' + escDesc + '</div>' +
                    '<div class="shell-cmd-del-cell"><button class="shell-cmd-del" data-idx="' + item.idx + '" title="\u5220\u9664"><span class="material-icons-round" style="font-size:16px">close</span></button></div>';
                row.addEventListener('click', function (e) {
                    if (e.target.closest('.shell-cmd-del')) return;
                    if (activeSession && activeSession.isConnected && activeSession.writer) {
                        sendData(activeSession, item.cmd);
                        if (activeSession.term) activeSession.term.focus();
                    } else {
                        sendInput.value = item.cmd;
                        sendInput.focus();
                    }
                });
                row.addEventListener('contextmenu', function (e) {
                    e.preventDefault();
                    if (e.target.closest('.shell-cmd-del')) return;
                    navigator.clipboard.writeText(item.cmd).then(function () {
                        showToast('\u5df2\u590d\u5236\u547d\u4ee4', 'ok');
                    }).catch(function () { showToast('\u590d\u5236\u5931\u8d25', 'error'); });
                });
                tableObj.appendChild(row);
            });
            g.innerHTML = titleHtml;
            g.appendChild(tableObj);
            listEl.appendChild(g);
        });
        listEl.querySelectorAll('.shell-cmd-del').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                var cmdPanel = document.getElementById('panel-cmd');
                if (!cmdPanel || !cmdPanel.classList.contains('editing')) return;
                cmds.splice(parseInt(btn.getAttribute('data-idx')), 1);
                saveCmds(cmds); renderCmds();
            });
        });
    }
    addBtn.addEventListener('click', function () {
        var cmd = cmdInput.value.trim();
        if (!cmd) { cmdInput.focus(); return; }
        cmds.push({ cat: catSelect.value, cmd: cmd, desc: descInput.value.trim() });
        saveCmds(cmds); renderCmds();
        cmdInput.value = ''; descInput.value = '';
    });
    cmdInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') addBtn.click(); });
    renderCmds();

    var primarySidebar = document.getElementById('primary-sidebar');
    var resizeHandle = document.getElementById('sidebar-resize-handle');
    var activityIcon = document.querySelector('.activity-icon');
    if (activityIcon) {
        activityIcon.addEventListener('click', function () {
            var isCollapsed = primarySidebar.classList.toggle('collapsed');
            resizeHandle.style.display = isCollapsed ? 'none' : 'flex';
            this.classList.toggle('active', !isCollapsed);
            setTimeout(function () { sessions.forEach(function (s) { if (s.fitAddon) try { s.fitAddon.fit(); } catch (ex) { } }); }, 250);
        });
    }
    var editBtn = document.getElementById('btn-edit-cmds');
    var cmdPanel = document.getElementById('panel-cmd');
    editBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        cmdPanel.classList.toggle('editing');
        editBtn.classList.toggle('active');
        renderCmds();
    });
})();

initChartJS();
createSession();
        }

    
        document.addEventListener('astro:page-load', function() { window.__serialDebugInit = false; initSerialDebug(); });
    </script>
</Layout>
