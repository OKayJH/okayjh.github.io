---
const apiUrl = import.meta.env.PUBLIC_AI_GATEWAY_URL ?? '';
const enabled =
  Boolean(apiUrl) && import.meta.env.PUBLIC_AI_ASSISTANT_ENABLED !== 'false';
const assistantName = import.meta.env.PUBLIC_AI_ASSISTANT_NAME ?? '\u5c0fO';
const titleText = `${assistantName} \u52a9\u624b`;
const subtitleText = 'OKay\u7684\u667a\u80fd\u52a9\u624b';
const clearText = '\u6e05\u7a7a\u5bf9\u8bdd';
const closeText = '\u5173\u95ed';
const welcomeText = `\u4f60\u597d\uff0c\u6211\u662f${assistantName}\u3002\u6709\u4ec0\u4e48\u53ef\u4ee5\u5e2e\u5230\u4f60\uff1f`;
const statusReadyText = '\u5c31\u7eea';
const inputPlaceholder = `\u7ed9 ${assistantName} \u53d1\u9001\u6d88\u606f`;
const stopText = '\u505c\u6b62';
const sendText = '\u53d1\u9001';
---

{enabled && (
  <div class="ai-assistant-root" data-assistant-name={assistantName} data-api-url={apiUrl}>
    <button
      id="ai-toggle-btn"
      class="ai-toggle-btn"
      type="button"
      aria-controls="ai-panel"
      aria-expanded="false"
      title={titleText}
    >
      <span class="ai-mini-robot" aria-hidden="true">
        <span class="ai-robot-shadow"></span>
        <span class="ai-robot">
          <span class="ai-robot-antenna">
            <span class="ai-robot-antenna-dot"></span>
          </span>
          <span class="ai-robot-head">
            <span class="ai-robot-head-gloss"></span>
            <span class="ai-robot-screen">
              <span class="ai-robot-eyes">
                <span class="ai-robot-eye">
                  <span class="ai-robot-pupil"></span>
                </span>
                <span class="ai-robot-eye">
                  <span class="ai-robot-pupil"></span>
                </span>
              </span>
              <span class="ai-robot-mouth"></span>
            </span>
          </span>
          <span class="ai-robot-body">
            <span class="ai-robot-body-core"></span>
            <span class="ai-robot-arm ai-robot-arm-left"></span>
            <span class="ai-robot-arm ai-robot-arm-right"></span>
          </span>
          <span class="ai-robot-legs">
            <span class="ai-robot-leg"><span class="ai-robot-foot"></span></span>
            <span class="ai-robot-leg"><span class="ai-robot-foot"></span></span>
          </span>
        </span>
      </span>
      <span class="ai-toggle-label">{assistantName}</span>
    </button>

    <section id="ai-panel" class="ai-panel hidden" aria-live="polite">
      <header class="ai-panel-header">
        <div class="ai-panel-title-wrap">
          <strong class="ai-panel-title">{assistantName}</strong>
          <span class="ai-panel-subtitle">{subtitleText}</span>
        </div>
        <div class="ai-panel-actions">
          <button id="ai-clear-btn" class="ai-icon-btn" type="button" title={clearText}>
            <span class="material-icons-round">delete_sweep</span>
          </button>
          <button id="ai-close-btn" class="ai-icon-btn" type="button" title={closeText}>
            <span class="material-icons-round">close</span>
          </button>
        </div>
      </header>

      <div id="ai-messages" class="ai-messages">
        <div class="ai-msg ai-msg-assistant">
          <p>{welcomeText}</p>
        </div>
      </div>

      <div class="ai-status-row">
        <span id="ai-status" class="ai-status">{statusReadyText}</span>
      </div>

      <form id="ai-form" class="ai-form">
        <textarea
          id="ai-input"
          class="ai-input"
          rows="3"
          placeholder={inputPlaceholder}
          maxlength="600"
        ></textarea>
        <div class="ai-form-actions">
          <button id="ai-stop-btn" class="ai-secondary-btn hidden" type="button">{stopText}</button>
          <button id="ai-send-btn" class="ai-send-btn" type="submit">{sendText}</button>
        </div>
      </form>
    </section>
  </div>
)}

<script is:inline>
  (() => {
    const bindAssistant = () => {
      const root = document.querySelector('.ai-assistant-root');
      if (!root) return;
      if (root.getAttribute('data-mounted') === 'true') return;
      root.setAttribute('data-mounted', 'true');

      const assistantName = root.getAttribute('data-assistant-name') || '\u5c0fO';
      const endpoint = root.getAttribute('data-api-url') || '';

      const panel = document.getElementById('ai-panel');
      const toggleBtn = document.getElementById('ai-toggle-btn');
      const closeBtn = document.getElementById('ai-close-btn');
      const clearBtn = document.getElementById('ai-clear-btn');
      const form = document.getElementById('ai-form');
      const input = document.getElementById('ai-input');
      const sendBtn = document.getElementById('ai-send-btn');
      const stopBtn = document.getElementById('ai-stop-btn');
      const statusEl = document.getElementById('ai-status');
      const messagesWrap = document.getElementById('ai-messages');
      const robot = root.querySelector('.ai-robot');
      const pupils = Array.from(root.querySelectorAll('.ai-robot-pupil'));

      /** @type {{ role: 'user' | 'assistant'; content: string }[]} */
      const messages = [];
      let isSending = false;
      let activeController = null;

      const escapeHtml = (raw) =>
        raw
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');

      const nowTime = () =>
        new Date().toLocaleTimeString('zh-CN', {
          hour: '2-digit',
          minute: '2-digit',
        });

      const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

      const resetRobotPose = () => {
        root.style.setProperty('--bot-shift-x', '0px');
        root.style.setProperty('--bot-shift-y', '0px');
        root.style.setProperty('--bot-tilt', '0deg');
        pupils.forEach((pupil) => {
          pupil.style.setProperty('--bot-look-x', '0px');
          pupil.style.setProperty('--bot-look-y', '0px');
        });
      };

      const setRobotPose = (clientX, clientY, intensity = 1) => {
        if (!robot) return;

        pupils.forEach((pupil) => {
          const eye = pupil.parentElement;
          if (!eye) return;
          const rect = eye.getBoundingClientRect();
          const eyeX = rect.left + rect.width / 2;
          const eyeY = rect.top + rect.height / 2;
          const deltaX = clientX - eyeX;
          const deltaY = clientY - eyeY;
          const angle = Math.atan2(deltaY, deltaX);
          const distance = Math.min(3, Math.hypot(deltaX, deltaY) / 22) * intensity;
          pupil.style.setProperty('--bot-look-x', `${(Math.cos(angle) * distance).toFixed(2)}px`);
          pupil.style.setProperty('--bot-look-y', `${(Math.sin(angle) * distance).toFixed(2)}px`);
        });

        const rect = robot.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height * 0.42;
        const deltaX = clientX - centerX;
        const deltaY = clientY - centerY;

        root.style.setProperty('--bot-shift-x', `${clamp(deltaX * 0.04 * intensity, -6, 6).toFixed(2)}px`);
        root.style.setProperty('--bot-shift-y', `${clamp(deltaY * 0.016 * intensity, -4, 4).toFixed(2)}px`);
        root.style.setProperty('--bot-tilt', `${clamp(deltaX * 0.028 * intensity, -10, 10).toFixed(2)}deg`);
      };

      const lookAtElement = (element, intensity = 0.78) => {
        if (!element) return;
        const rect = element.getBoundingClientRect();
        const targetX = rect.left + rect.width * 0.78;
        const targetY = rect.top + rect.height / 2;
        setRobotPose(targetX, targetY, intensity);
      };

      const setStatus = (text, kind = 'normal') => {
        if (!statusEl) return;
        statusEl.textContent = text;
        statusEl.classList.remove('is-error', 'is-busy');
        if (kind === 'error') statusEl.classList.add('is-error');
        if (kind === 'busy') statusEl.classList.add('is-busy');
      };

      const scrollToBottom = () => {
        if (!messagesWrap) return;
        messagesWrap.scrollTop = messagesWrap.scrollHeight;
      };

      const addMessage = (role, content) => {
        if (!messagesWrap) return null;
        const item = document.createElement('div');
        item.className = `ai-msg ${role === 'assistant' ? 'ai-msg-assistant' : 'ai-msg-user'}`;
        item.innerHTML = `<p>${escapeHtml(content).replace(/\n/g, '<br>')}</p><time>${nowTime()}</time>`;
        messagesWrap.appendChild(item);
        scrollToBottom();
        return item;
      };

      const updateMessage = (item, content) => {
        if (!item) return;
        const p = item.querySelector('p');
        if (p) {
          p.innerHTML = escapeHtml(content).replace(/\n/g, '<br>');
        }
        scrollToBottom();
      };

      const setPanelOpen = (open) => {
        if (!panel || !toggleBtn) return;
        panel.classList.toggle('hidden', !open);
        root.classList.toggle('panel-open', open);
        toggleBtn.setAttribute('aria-expanded', String(open));
        if (open && input) {
          input.focus();
        } else {
          root.classList.remove('input-focused');
          resetRobotPose();
        }
      };

      const setBusy = (busy) => {
        isSending = busy;
        if (sendBtn) sendBtn.disabled = busy;
        if (input) input.disabled = busy;
        if (stopBtn) stopBtn.classList.toggle('hidden', !busy);
        if (busy) {
          root.classList.remove('input-focused');
        }
      };

      const buildRequestMessages = () => {
        const history = messages.slice(-4);
        return history.map((m) => ({ role: m.role, content: m.content }));
      };

      const parseSseData = (raw) => {
        if (!raw) return '';
        if (raw === '[DONE]') return '__DONE__';

        try {
          const parsed = JSON.parse(raw);
          if (parsed?.error?.message) {
            throw new Error(parsed.error.message);
          }
          if (typeof parsed?.text === 'string') {
            return parsed.text;
          }
          if (typeof parsed?.delta === 'string') {
            return parsed.delta;
          }
          const maybe = parsed?.choices?.[0]?.delta?.content;
          if (typeof maybe === 'string') {
            return maybe;
          }
          return '';
        } catch {
          return raw;
        }
      };

      const readSseStream = async (stream, onDelta) => {
        const reader = stream.getReader();
        const decoder = new TextDecoder('utf-8');
        let buffer = '';

        while (true) {
          const { value, done } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });

          let splitIndex = buffer.indexOf('\n\n');
          while (splitIndex !== -1) {
            const rawEvent = buffer.slice(0, splitIndex).trim();
            buffer = buffer.slice(splitIndex + 2);

            if (rawEvent) {
              const lines = rawEvent.split('\n');
              const data = lines
                .filter((line) => line.startsWith('data:'))
                .map((line) => line.slice(5).trim())
                .join('\n');

              if (data) {
                const parsed = parseSseData(data);
                if (parsed === '__DONE__') return;
                if (parsed) onDelta(parsed);
              }
            }

            splitIndex = buffer.indexOf('\n\n');
          }
        }
      };

      const sendMessage = async (text) => {
        if (!endpoint) {
          setStatus('\u672a\u914d\u7f6e AI \u7f51\u5173\u5730\u5740\uff0c\u8bf7\u8054\u7cfb\u7ad9\u957f\u3002', 'error');
          return;
        }

        const userText = text.trim();
        if (!userText) return;

        setBusy(true);
        setStatus('\u601d\u8003\u4e2d...', 'busy');
        addMessage('user', userText);
        messages.push({ role: 'user', content: userText });
        input.value = '';

        const assistantItem = addMessage('assistant', '');
        let assistantText = '';
        activeController = new AbortController();

        // Start thinking animation
        root.classList.add('is-thinking');

        try {
          const payload = {
            assistant: assistantName,
            messages: buildRequestMessages(),
            page: {
              title: document.title,
              path: window.location.pathname,
              url: window.location.href,
            },
          };

          const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
            signal: activeController.signal,
          });

          if (!response.ok) {
            const textResp = await response.text();
            throw new Error(textResp || `\u8bf7\u6c42\u5931\u8d25\uff08${response.status}\uff09`);
          }

          const contentType = response.headers.get('content-type') || '';
          if (contentType.includes('text/event-stream') && response.body) {
            // Start speaking animation once we know we are getting a stream
            root.classList.remove('is-thinking');
            root.classList.add('is-speaking');
            
            await readSseStream(response.body, (delta) => {
              assistantText += delta;
              updateMessage(assistantItem, assistantText);
            });
          } else {
            root.classList.remove('is-thinking');
            const data = await response.json();
            assistantText =
              data?.answer ||
              data?.text ||
              data?.choices?.[0]?.message?.content ||
              '\u8fd9\u6b21\u6ca1\u6709\u8fd4\u56de\u53ef\u7528\u5185\u5bb9\u3002';
            updateMessage(assistantItem, assistantText);
          }

          const finalText = assistantText.trim() || '\u8fd9\u6b21\u6ca1\u6709\u751f\u6210\u6709\u6548\u56de\u590d\u3002';
          updateMessage(assistantItem, finalText);
          messages.push({ role: 'assistant', content: finalText });
          setStatus('\u5c31\u7eea');
        } catch (error) {
          const message =
            error?.name === 'AbortError'
              ? '\u5df2\u505c\u6b62\u751f\u6210\u3002'
              : `\u8bf7\u6c42\u5931\u8d25\uff1a${error?.message || '\u672a\u77e5\u9519\u8bef'}`;
          updateMessage(assistantItem, message);
          messages.push({ role: 'assistant', content: message });
          setStatus(message, 'error');
        } finally {
          activeController = null;
          setBusy(false);
          // Stop all animations
          root.classList.remove('is-thinking', 'is-speaking');
        }
      };

      if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
          const isOpen = panel ? !panel.classList.contains('hidden') : false;
          setPanelOpen(!isOpen);
        });

        toggleBtn.addEventListener('mouseenter', () => {
          root.classList.add('is-hovered');
        });

        toggleBtn.addEventListener('mouseleave', () => {
          root.classList.remove('is-hovered');
        });

        toggleBtn.addEventListener('focus', () => {
          root.classList.add('is-hovered');
        });

        toggleBtn.addEventListener('blur', () => {
          if (document.activeElement !== input) {
            root.classList.remove('is-hovered');
          }
        });
      }

      if (closeBtn) {
        closeBtn.addEventListener('click', () => setPanelOpen(false));
      }

      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          messages.length = 0;
          if (messagesWrap) messagesWrap.innerHTML = '';
          addMessage('assistant', `\u4e0a\u4e0b\u6587\u5df2\u6e05\u7a7a\u3002\u4f60\u53ef\u4ee5\u7ee7\u7eed\u5411 ${assistantName} \u63d0\u95ee\u3002`);
          setStatus('\u5bf9\u8bdd\u5df2\u6e05\u7a7a');
        });
      }

      if (stopBtn) {
        stopBtn.addEventListener('click', () => {
          if (activeController) activeController.abort();
        });
      }

      if (input) {
        input.addEventListener('focus', () => {
          root.classList.add('input-focused');
          lookAtElement(input);
        });

        input.addEventListener('blur', () => {
          root.classList.remove('input-focused');
          if (!root.classList.contains('panel-open')) {
            resetRobotPose();
          }
        });

        input.addEventListener('input', () => {
          if (root.classList.contains('input-focused')) {
            lookAtElement(input);
          }
        });

        input.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            if (!isSending) sendMessage(input.value);
          }
        });
      }

      document.addEventListener('mousemove', (event) => {
        if (root.classList.contains('input-focused') || root.classList.contains('is-thinking')) return;
        setRobotPose(event.clientX, event.clientY, root.classList.contains('panel-open') ? 0.86 : 1);
      }, { passive: true });

      resetRobotPose();

      if (form) {
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          if (!isSending) sendMessage(input.value);
        });
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindAssistant, { once: true });
    } else {
      bindAssistant();
    }

    document.addEventListener('astro:page-load', bindAssistant);
  })();
</script>

<style>
  .ai-assistant-root {
    position: fixed;
    right: 18px;
    bottom: 82px;
    z-index: 5500;
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-end;
    gap: 12px;
    --bot-shift-x: 0px;
    --bot-shift-y: 0px;
    --bot-tilt: 0deg;
  }

  .ai-toggle-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    background: transparent;
    color: var(--text);
    padding: 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .ai-toggle-btn:focus-visible {
    outline: none;
  }

  .ai-mini-robot {
    position: relative;
    width: 74px;
    height: 88px;
    flex: 0 0 auto;
  }

  .ai-robot-shadow {
    position: absolute;
    left: 50%;
    bottom: 2px;
    width: 48px;
    height: 14px;
    border-radius: 999px;
    background: rgba(59, 130, 246, 0.24);
    filter: blur(10px);
    transform: translateX(-50%);
    animation: aiRobotShadow 3.6s ease-in-out infinite;
  }

  .ai-robot {
    position: absolute;
    left: 50%;
    bottom: 2px;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translate(calc(-50% + var(--bot-shift-x)), var(--bot-shift-y)) rotate(var(--bot-tilt));
    transform-origin: center bottom;
    transition: transform 0.16s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .ai-robot-antenna {
    position: relative;
    width: 4px;
    height: 12px;
    margin-bottom: -2px;
    border-radius: 999px;
    background: linear-gradient(180deg, #8fb8ff, #5e81ff);
  }

  .ai-robot-antenna-dot {
    position: absolute;
    top: -8px;
    left: 50%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle at 35% 35%, #ffffff, #8bd0ff 48%, #4f7cff 100%);
    box-shadow: 0 0 0 4px rgba(79, 124, 255, 0.12);
    animation: aiRobotPulse 2.4s ease-in-out infinite;
  }

  .ai-robot-head {
    position: relative;
    width: 56px;
    height: 44px;
    border-radius: 18px 18px 16px 16px;
    background: linear-gradient(180deg, #ffffff, #edf4ff);
    border: 1px solid rgba(79, 124, 255, 0.18);
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.14);
    overflow: hidden;
  }

  .ai-robot-head-gloss {
    position: absolute;
    inset: 0;
    background: linear-gradient(140deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.18) 45%, transparent 46%);
    opacity: 0.72;
    pointer-events: none;
  }

  .ai-robot-screen {
    position: absolute;
    inset: 8px 9px 9px;
    border-radius: 12px;
    background: linear-gradient(180deg, #3753a8, #263f81);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .ai-robot-eyes {
    display: flex;
    gap: 10px;
  }

  .ai-robot-eye {
    position: relative;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.96);
    overflow: hidden;
    transition: width 0.2s ease, height 0.2s ease, border-radius 0.2s ease, transform 0.2s ease;
  }

  .ai-robot-eye::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #263f81;
    transform-origin: top;
    transform: scaleY(0);
    animation: aiRobotBlink 4.8s infinite;
    transition: transform 0.2s ease;
  }

  .ai-robot-pupil {
    position: absolute;
    top: 50%;
    left: 50%;
    height: 4px;
    width: 4px;
    border-radius: 50%;
    background: #4f7cff;
    box-shadow: 0 0 8px rgba(79, 124, 255, 0.42);
    transform: translate(calc(-50% + var(--bot-look-x, 0px)), calc(-50% + var(--bot-look-y, 0px)));
    transition: transform 0.08s ease-out;
  }

  .ai-robot-mouth {
    width: 16px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(135deg, #8de0ff, #d8f2ff);
    transition: all 0.2s ease;
  }

  .ai-robot-body {
    position: relative;
    width: 44px;
    height: 30px;
    margin-top: -4px;
    border-radius: 16px 16px 18px 18px;
    background: linear-gradient(180deg, #ffffff, #eaf2ff);
    border: 1px solid rgba(79, 124, 255, 0.16);
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.1);
  }

  .ai-robot-body-core {
    position: absolute;
    inset: 8px 11px;
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(79, 124, 255, 0.2), rgba(79, 124, 255, 0.06));
    border: 1px solid rgba(79, 124, 255, 0.18);
  }

  .ai-robot-arm {
    position: absolute;
    top: 6px;
    width: 18px;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(180deg, #7f92ff, #5d7bff);
    box-shadow: 0 2px 4px rgba(79, 124, 255, 0.2);
    transition: transform 0.22s ease;
  }

  .ai-robot-arm-left {
    left: -10px;
    transform-origin: right center;
    transform: rotate(24deg);
  }

  .ai-robot-arm-right {
    right: -10px;
    transform-origin: left center;
    transform: rotate(-24deg);
  }

  .ai-robot-legs {
    display: flex;
    gap: 12px;
    margin-top: -1px;
  }

  .ai-robot-leg {
    position: relative;
    width: 4px;
    height: 18px;
    border-radius: 999px;
    background: #4b5563;
  }

  .ai-robot-foot {
    position: absolute;
    left: 50%;
    bottom: -4px;
    width: 14px;
    height: 7px;
    border-radius: 6px 6px 4px 4px;
    background: #4f7cff;
    box-shadow: 0 2px 0 rgba(15, 23, 42, 0.08);
    transform: translateX(-50%);
  }

  .ai-toggle-label {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    margin-bottom: 10px;
