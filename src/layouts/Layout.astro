---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import AIAssistant from '../components/AIAssistant.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "嵌入式 Linux · AI · 硬件开发" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ViewTransitions />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			document.documentElement.setAttribute('data-theme', theme);
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body>
		<!-- Welcome Screen (Splash Animation) -->
		<div id="welcome-screen" class="welcome-screen">
			<div class="welcome-inner">
				<div class="welcome-logo-anim">
					<span class="welcome-letter" style="--i:0">O</span>
					<span class="welcome-letter" style="--i:1">K</span>
					<span class="welcome-letter" style="--i:2">a</span>
					<span class="welcome-letter" style="--i:3">y</span>
					<span class="welcome-letter dot" style="--i:4">'</span>
					<span class="welcome-letter" style="--i:5">s</span>
					<span class="welcome-letter space" style="--i:6">&nbsp;</span>
					<span class="welcome-letter" style="--i:7">B</span>
					<span class="welcome-letter" style="--i:8">l</span>
					<span class="welcome-letter" style="--i:9">o</span>
					<span class="welcome-letter" style="--i:10">g</span>
				</div>
				<p class="welcome-subtitle">嵌入式 Linux · AI · 硬件开发</p>
				<div class="welcome-loader">
					<div class="welcome-bar"></div>
				</div>
			</div>
		</div>

		<div id="app" class="app" style="opacity: 0; transition: opacity 0.5s ease;">
			<Header />
			
			<slot />

			<Footer />
			
			<MusicPlayer />
			<AIAssistant />
		</div>

		<script is:inline>
			(() => {
				const hasPlayed = sessionStorage.getItem('hasPlayedWelcome');
				const isRoot = window.location.pathname === '/' || window.location.pathname === '/index.html';
				
				// Play if they haven't seen it this session and are hitting the root page
				const shouldPlayAnimation = !hasPlayed && isRoot;

				const welcome = document.getElementById('welcome-screen');
				const app = document.getElementById('app');

				if (!shouldPlayAnimation) {
					if(welcome) welcome.style.display = 'none';
					if(app) {
						app.style.opacity = '1';
						app.style.visibility = 'visible';
					}
				} else {
					sessionStorage.setItem('hasPlayedWelcome', 'true');
					if(app) {
						app.style.opacity = '0';
						app.classList.remove('hidden');
					}
					if(welcome) {
						welcome.style.display = 'flex';
						welcome.classList.remove('fade-out');
					}

					const startAnim = () => {
						setTimeout(() => {
							const w = document.getElementById('welcome-screen');
							const a = document.getElementById('app');
							if(w) w.classList.add('fade-out');
							if(a) a.style.opacity = '1';
							setTimeout(() => {
								if(w) w.style.display = 'none';
							}, 600);
						}, 2500);
					};

					if (document.readyState === 'complete') {
						startAnim();
					} else {
						window.addEventListener('load', startAnim);
					}
				}

				// Keep track if we are in the middle of the initial splash animation
				let isInitialSplash = shouldPlayAnimation;

				// Handle subsequent Astro SPA navigations instantly
				document.addEventListener('astro:page-load', () => {
					if (isInitialSplash) {
						isInitialSplash = false; // Only allow skipping on actual navigations
						return;
					}

					const w = document.getElementById('welcome-screen');
					const a = document.getElementById('app');
					if (w) w.style.display = 'none';
					if (a) {
						a.style.opacity = '1';
						a.style.visibility = 'visible';
					}
				});
			})();
		</script>
	<!-- Developer Mode Hidden Trigger & Modal -->
		<div id="dev-trigger-area" style="position: fixed; bottom: 0; right: 0; width: 50px; height: 50px; z-index: 9998; cursor: default;"></div>
		
		<style is:inline>
			body.dev-modal-open { overflow: hidden; }
			.dev-auth-modal {
				position: fixed;
				inset: 0;
				z-index: 9999;
				display: none;
				align-items: center;
				justify-content: center;
				padding: 24px;
				background: rgba(10, 13, 24, 0.74);
				backdrop-filter: blur(18px);
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
				opacity: 0;
				transition: opacity 0.28s ease;
				user-select: none;
			}
			.dev-auth-modal.visible { opacity: 1; }
			.dev-login-card {
				position: relative;
				display: grid;
				grid-template-columns: minmax(320px, 44%) minmax(340px, 1fr);
				width: min(920px, 96vw);
				min-height: 540px;
				border-radius: 30px;
				overflow: hidden;
				border: 1px solid rgba(148, 163, 184, 0.18);
				background: var(--surface, #ffffff);
				box-shadow: 0 28px 80px rgba(15, 23, 42, 0.26);
				opacity: 0;
				transform: translateY(24px) scale(0.96);
				transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
			}
			.dev-auth-modal.visible .dev-login-card {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
			.dev-login-scene {
				position: relative;
				overflow: hidden;
				isolation: isolate;
				background: linear-gradient(180deg, #fffdf4 0%, #f4f4ee 58%, #f0efe7 100%);
			}
			html[data-theme="dark"] .dev-login-scene {
				background: linear-gradient(180deg, #1f2638 0%, #171f30 58%, #101827 100%);
			}
			.dev-login-scene::before {
				content: "";
				position: absolute;
				inset: 18px;
				border-radius: 28px;
				border: 1px solid rgba(255, 214, 10, 0.44);
				pointer-events: none;
				opacity: 0.78;
			}
			.scene-glow {
				position: absolute;
				border-radius: 999px;
				filter: blur(18px);
				opacity: 0.72;
				pointer-events: none;
			}
			.scene-glow-left {
				top: 42px;
				left: -12px;
				width: 160px;
				height: 160px;
				background: rgba(255, 111, 34, 0.18);
			}
			.scene-glow-right {
				top: 86px;
				right: -24px;
				width: 180px;
				height: 180px;
				background: rgba(141, 209, 229, 0.22);
			}
			.scene-orbit {
				position: absolute;
				border: 4px solid rgba(255, 214, 10, 0.78);
				border-radius: 999px;
				opacity: 0.58;
				animation: orbitFloat 9s ease-in-out infinite;
			}
			.orbit-a {
				top: 48px;
				right: 42px;
				width: 120px;
				height: 120px;
			}
			.orbit-b {
				top: 142px;
				left: 42px;
				width: 72px;
				height: 72px;
				animation-delay: -2.8s;
			}
			.orbit-c {
				top: 220px;
				right: 118px;
				width: 28px;
				height: 28px;
				background: rgba(255, 255, 255, 0.42);
				border: none;
				animation-duration: 6s;
				animation-delay: -1.4s;
			}
			.scene-stage {
				position: absolute;
				left: 20px;
				right: 20px;
				bottom: 18px;
				height: 18px;
				border-radius: 999px;
				background: linear-gradient(180deg, rgba(255, 214, 10, 0.72), rgba(255, 214, 10, 0.18));
				box-shadow: 0 24px 40px rgba(255, 214, 10, 0.2);
			}
			html[data-theme="dark"] .scene-stage {
				background: linear-gradient(180deg, rgba(255, 214, 10, 0.28), rgba(255, 214, 10, 0.05));
				box-shadow: 0 24px 40px rgba(2, 6, 23, 0.38);
			}
			.chars-container {
				position: absolute;
				left: 50%;
				bottom: 18px;
				width: min(390px, 92%);
				height: 360px;
				transform: translateX(-50%);
			}
			.dev-char {
				--char-color: #9a74e8;
				--lid-color: var(--char-color);
				--shape-width: 120px;
				--shape-height: 120px;
				--eye-width: 10px;
				--eye-height: 20px;
				--eye-gap: 18px;
				--face-top: 42px;
				--cheek-color: #ff9b9b;
				--cheek-size: 18px;
				--cheek-gap: 64px;
				--leg-span: 54px;
				--leg-height: 26px;
				--shoe-color: #ffffff;
				--shoe-accent: #7aa7f8;
				--shadow-width: 82px;
				--blink-delay: 0s;
				--turn-direction: 1;
				--turn-scale: -0.94;
				--buddy-x: 0px;
				--buddy-y: 0px;
				--buddy-rotate: 0deg;
				--buddy-face-x: 0px;
				--buddy-face-y: 0px;
				--privacy-x: 0px;
				--privacy-y: 0px;
				--privacy-rotate: 0deg;
				--privacy-scale-x: 1;
				--privacy-face-x: 0px;
				--privacy-face-y: 0px;
				position: absolute;
				bottom: 0;
				left: 0;
				opacity: 0;
				transform-origin: bottom center;
				filter: drop-shadow(0 18px 24px rgba(15, 23, 42, 0.14));
			}
			.dev-char::after {
				content: "";
				position: absolute;
				left: 50%;
				bottom: 8px;
				width: var(--shadow-width);
				height: 18px;
				border-radius: 999px;
				background: rgba(15, 23, 42, 0.2);
				filter: blur(11px);
				transform: translateX(-50%);
				opacity: 0.4;
				z-index: -1;
				animation: shadowPulse 3.2s ease-in-out infinite;
				animation-play-state: paused;
			}
			.dev-auth-modal.visible .dev-char::after { animation-play-state: running; }
			.dev-char-motion {
				position: relative;
				display: flex;
				flex-direction: column;
				align-items: center;
				transform:
					translate3d(
						calc(var(--body-x, 0px) + var(--buddy-x, 0px) + var(--privacy-x, 0px)),
						calc(var(--body-y, 0px) + var(--buddy-y, 0px) + var(--privacy-y, 0px)),
						0
					)
					rotate(calc(var(--body-rotate, 0deg) + var(--buddy-rotate, 0deg) + var(--privacy-rotate, 0deg)));
				transition: transform 0.24s cubic-bezier(0.22, 1, 0.36, 1);
				will-change: transform;
			}
			.dev-char-shape {
				position: relative;
				width: var(--shape-width);
				height: var(--shape-height);
				background: var(--char-color);
				box-shadow: inset 0 -8px 0 rgba(0, 0, 0, 0.06);
				overflow: hidden;
			}
			.dev-char-back {
				position: absolute;
				inset: 24% 26%;
				opacity: 0;
				transform: scale(0.84);
				transition: opacity 0.24s ease, transform 0.24s ease;
			}
			.dev-char-back::before,
			.dev-char-back::after {
				content: "";
				position: absolute;
				top: 18%;
				width: 16%;
				height: 48%;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.18);
			}
			.dev-char-back::before { left: 24%; }
			.dev-char-back::after { right: 24%; }
			.dev-face {
				position: absolute;
				left: 50%;
				top: var(--face-top);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 10px;
				transform:
					translate(
						calc(-50% + var(--face-x, 0px) + var(--buddy-face-x, 0px) + var(--privacy-face-x, 0px)),
						calc(var(--face-y, 0px) + var(--buddy-face-y, 0px) + var(--privacy-face-y, 0px))
					);
				transition: transform 0.24s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease;
				will-change: transform;
				z-index: 2;
			}
			.dev-cheeks {
				position: absolute;
				top: 10px;
				left: 50%;
				width: var(--cheek-gap);
				transform: translateX(-50%);
				display: flex;
				justify-content: space-between;
				pointer-events: none;
			}
			.dev-cheek {
				width: var(--cheek-size);
				height: var(--cheek-size);
				border-radius: 50%;
				background: var(--cheek-color);
				opacity: 0.94;
			}
			.dev-eyes {
				position: relative;
				z-index: 2;
				display: flex;
				gap: var(--eye-gap);
			}
			.dev-eye {
				position: relative;
				width: var(--eye-width);
				height: var(--eye-height);
				overflow: hidden;
			}
			.dev-eye::before {
				content: "";
				position: absolute;
				inset: -1px;
				background: var(--lid-color);
				transform-origin: top;
				transform: scaleY(0);
				transition: transform 0.24s ease;
				animation: blink 6.1s infinite;
				animation-delay: var(--blink-delay);
				z-index: 2;
			}
			.dev-pupil {
				position: absolute;
				top: 50%;
				left: 50%;
				width: max(3px, calc(var(--eye-width) * 0.34));
				height: calc(var(--eye-height) * 0.82);
				border-radius: 999px;
				background: #111827;
				transform: translate(calc(-50% + var(--look-x, 0px)), calc(-50% + var(--look-y, 0px)));
				transition: transform 0.08s ease-out, opacity 0.18s ease;
			}
			.dev-mouth {
				position: relative;
				z-index: 2;
				width: 28px;
				height: 14px;
				transition: all 0.28s ease;
			}
			.mouth-frown {
				border-top: 3px solid #111827;
				border-radius: 28px 28px 0 0;
			}
			.mouth-smile {
				border-bottom: 3px solid #111827;
				border-radius: 0 0 28px 28px;
			}
			.mouth-smile-wide {
				width: 54px;
				height: 18px;
				border-bottom: 4px solid #111827;
				border-radius: 0 0 56px 56px;
			}
			.mouth-o {
				width: 14px;
				height: 14px;
				border: 3px solid #111827;
				border-radius: 50%;
			}
			.mouth-zigzag {
				width: 34px;
				height: 16px;
				background:
					linear-gradient(45deg, transparent 42%, #111827 42% 54%, transparent 54%) left center / 50% 100% no-repeat,
					linear-gradient(-45deg, transparent 42%, #111827 42% 54%, transparent 54%) center center / 50% 100% no-repeat,
					linear-gradient(45deg, transparent 42%, #111827 42% 54%, transparent 54%) right center / 50% 100% no-repeat;
			}
			.face-angry .dev-eye:first-child,
			.face-playful .dev-eye:first-child { transform: rotate(16deg); }
			.face-angry .dev-eye:last-child,
			.face-playful .dev-eye:last-child { transform: rotate(-16deg); }
			.face-sad .dev-eye:first-child { transform: rotate(14deg); }
			.face-sad .dev-eye:last-child { transform: rotate(-14deg); }
			.dev-legs {
				display: flex;
				justify-content: space-between;
				width: var(--leg-span);
				margin-top: -4px;
			}
			.dev-leg {
				display: flex;
				flex-direction: column;
				align-items: center;
			}
			.dev-shin {
				width: 2.5px;
				height: var(--leg-height);
				border-radius: 999px;
				background: #111827;
			}
			.dev-leg:first-child .dev-shin { transform: rotate(1deg); }
			.dev-leg:last-child .dev-shin { transform: rotate(-1deg); }
			.dev-shoe {
				width: 16px;
				height: 10px;
				margin-top: 2px;
				border-radius: 2px 2px 0 0;
				background: var(--shoe-color);
				box-shadow: 6px 3px 0 var(--shoe-accent);
			}
			.dev-leg:first-child .dev-shoe { transform: translateX(-5px) rotate(2deg); }
			.dev-leg:last-child .dev-shoe { transform: translateX(5px) rotate(-2deg); }
			.char-star {
				left: 0;
				bottom: 44px;
				z-index: 4;
				--turn-direction: -1;
				--turn-scale: -0.96;
				--char-color: #ff5d17;
				--shape-width: 176px;
				--shape-height: 168px;
				--face-top: 58px;
				--eye-width: 12px;
				--eye-height: 20px;
				--eye-gap: 20px;
				--cheek-color: #ef2920;
				--cheek-size: 20px;
				--cheek-gap: 80px;
				--leg-span: 62px;
				--leg-height: 44px;
				--shoe-color: #ff6a28;
				--shoe-accent: #f7c21a;
				--shadow-width: 104px;
				--blink-delay: 0.3s;
			}
			.char-star .dev-char-shape {
				clip-path: polygon(50% 0%, 60% 20%, 82% 5%, 73% 28%, 100% 34%, 78% 47%, 97% 68%, 72% 70%, 80% 95%, 57% 80%, 50% 100%, 42% 80%, 20% 95%, 28% 70%, 4% 68%, 23% 48%, 0% 34%, 27% 28%, 18% 5%, 40% 21%);
			}
			.char-cloud {
				left: 6px;
				bottom: 2px;
				z-index: 5;
				--turn-direction: -1;
				--turn-scale: -0.92;
				--char-color: #0b4dc5;
				--shape-width: 122px;
				--shape-height: 92px;
				--face-top: 28px;
				--eye-width: 10px;
				--eye-height: 18px;
				--eye-gap: 18px;
				--cheek-color: #7dc4e6;
				--cheek-gap: 72px;
				--leg-span: 56px;
				--leg-height: 28px;
				--shoe-color: #0b4dc5;
				--shoe-accent: #74a9ff;
				--shadow-width: 76px;
				--blink-delay: 1.6s;
			}
			.char-cloud .dev-char-shape {
				clip-path: polygon(13% 18%, 27% 9%, 43% 13%, 58% 6%, 75% 12%, 90% 28%, 95% 48%, 91% 71%, 76% 86%, 56% 91%, 38% 88%, 18% 92%, 5% 74%, 1% 50%, 5% 28%);
			}
			.char-purple {
				left: 126px;
				bottom: 64px;
				z-index: 2;
				--turn-direction: 1;
				--turn-scale: 0.92;
				--char-color: #9877df;
				--shape-width: 152px;
				--shape-height: 188px;
				--face-top: 58px;
				--eye-width: 12px;
				--eye-height: 22px;
				--eye-gap: 22px;
				--cheek-color: #ffd020;
				--cheek-gap: 88px;
				--leg-span: 58px;
				--leg-height: 34px;
				--shoe-color: #c59bff;
				--shoe-accent: #ffd74c;
				--shadow-width: 92px;
				--blink-delay: 2.3s;
			}
			.char-purple .dev-char-shape {
				border-radius: 48% 48% 36% 36% / 54% 54% 28% 28%;
			}
			.char-triangle {
				left: 128px;
				bottom: 6px;
				z-index: 6;
				--turn-direction: -1;
				--turn-scale: -0.9;
				--char-color: #09b565;
				--shape-width: 148px;
				--shape-height: 142px;
				--face-top: 60px;
				--eye-width: 11px;
				--eye-height: 20px;
				--eye-gap: 20px;
				--cheek-color: #f6c0b5;
				--cheek-gap: 74px;
				--leg-span: 64px;
				--leg-height: 34px;
				--shoe-color: #09b565;
				--shoe-accent: #ab86f5;
				--shadow-width: 88px;
				--blink-delay: 3.05s;
			}
			.char-triangle .dev-char-shape {
				clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
			}
			.char-diamond {
				left: 272px;
				bottom: 150px;
				z-index: 1;
				--turn-direction: 1;
				--turn-scale: 0.9;
				--char-color: #8cd3e7;
				--shape-width: 116px;
				--shape-height: 116px;
				--face-top: 42px;
				--eye-width: 11px;
				--eye-height: 18px;
				--eye-gap: 18px;
				--cheek-color: #f7a6ba;
				--cheek-gap: 70px;
				--leg-span: 44px;
				--leg-height: 30px;
				--shoe-color: #ffffff;
				--shoe-accent: #9ec9d9;
				--shadow-width: 66px;
				--blink-delay: 0.95s;
			}
			.char-diamond .dev-char-shape {
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
			}
			.char-circle {
				left: 244px;
				bottom: 18px;
				z-index: 5;
				--turn-direction: 1;
				--turn-scale: 0.94;
				--char-color: #ffd408;
				--shape-width: 154px;
				--shape-height: 154px;
				--face-top: 50px;
