<button
  id="back-to-top-btn"
  class="back-to-top-btn"
  type="button"
  aria-label="回到顶部"
  title="回到顶部"
>
  <span class="material-icons-round" aria-hidden="true">keyboard_arrow_up</span>
  <span class="back-to-top-sr">回到顶部</span>
</button>

<script is:inline>
  (() => {
    const mountBackToTop = () => {
      const button = document.getElementById('back-to-top-btn');
      if (!button) return;

      if (window._okayBackToTopCleanup) {
        window._okayBackToTopCleanup();
      }

      const getBaseOffsets = () => {
        const isMobile = window.matchMedia('(max-width: 768px)').matches;
        return {
          baseRight: isMobile ? 12 : 20,
          baseBottom: isMobile ? 78 : 84,
          gap: isMobile ? 10 : 12
        };
      };

      const updatePosition = () => {
        const { baseRight, baseBottom, gap } = getBaseOffsets();
        const assistantRoot = document.querySelector('.ai-assistant-root');
        const toggleBtn = assistantRoot?.querySelector('#ai-toggle-btn');
        const panel = assistantRoot?.querySelector('#ai-panel');
        const maxRight = Math.max(baseRight, window.innerWidth - button.offsetWidth - baseRight);

        let right = baseRight;
        let bottom = baseBottom;

        if (toggleBtn instanceof HTMLElement) {
          const toggleRect = toggleBtn.getBoundingClientRect();
          right = Math.min(
            Math.max(baseRight, Math.round(window.innerWidth - toggleRect.left + gap)),
            maxRight
          );
          bottom = Math.max(baseBottom, Math.round(window.innerHeight - toggleRect.bottom));
        }

        if (panel instanceof HTMLElement && !panel.classList.contains('hidden')) {
          const panelRect = panel.getBoundingClientRect();
          right = baseRight;
          bottom = Math.max(bottom, Math.round(window.innerHeight - panelRect.top + gap));
        }

        button.style.right = `${right}px`;
        button.style.bottom = `${bottom}px`;
      };

      const updateVisibility = () => {
        button.classList.toggle('is-visible', window.scrollY > 0);
      };

      const scrollToTop = () => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({
          top: 0,
          behavior: prefersReducedMotion ? 'auto' : 'smooth'
        });
      };

      const handleViewportChange = () => {
        updatePosition();
        updateVisibility();
      };

      const assistantRoot = document.querySelector('.ai-assistant-root');
      let assistantObserver = null;

      button.addEventListener('click', scrollToTop);
      window.addEventListener('scroll', updateVisibility, { passive: true });
      window.addEventListener('resize', handleViewportChange, { passive: true });

      if (assistantRoot instanceof HTMLElement) {
        assistantObserver = new MutationObserver(() => {
          updatePosition();
        });

        assistantObserver.observe(assistantRoot, {
          attributes: true,
          childList: true,
          subtree: true
        });
      }

      updatePosition();
      updateVisibility();

      window._okayBackToTopCleanup = () => {
        button.removeEventListener('click', scrollToTop);
        window.removeEventListener('scroll', updateVisibility);
        window.removeEventListener('resize', handleViewportChange);
        assistantObserver?.disconnect();
      };
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mountBackToTop, { once: true });
    } else {
      mountBackToTop();
    }

    document.addEventListener('astro:page-load', mountBackToTop);
  })();
</script>

<style>
  .back-to-top-btn {
    position: fixed;
    right: 20px;
    bottom: 84px;
    z-index: 5600;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #ffb347, #ff8f1f);
    color: #ffffff;
    box-shadow: 0 12px 28px rgba(255, 143, 31, 0.3);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(10px) scale(0.96);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease,
      visibility 0.22s ease,
      box-shadow 0.22s ease,
      filter 0.22s ease;
  }

  .back-to-top-btn.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .back-to-top-btn:hover {
    filter: brightness(1.03);
    box-shadow: 0 16px 32px rgba(255, 143, 31, 0.38);
  }

  .back-to-top-btn:active {
    transform: translateY(1px) scale(0.97);
  }

  .back-to-top-btn .material-icons-round {
    font-size: 24px;
    line-height: 1;
  }

  .back-to-top-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .back-to-top-btn {
      right: 12px;
      bottom: 78px;
      width: 42px;
      height: 42px;
      border-radius: 11px;
    }
  }
</style>
