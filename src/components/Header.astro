---
// src/components/Header.astro
---

<nav class="navbar" id="navbar">
    <div class="nav-inner">
        <a href="/" class="nav-logo">
            <span class="logo-icon material-icons-round">memory</span>
            <span class="logo-text">OKay<span class="logo-accent">.dev</span></span>
        </a>
        <div class="nav-center">
            <div class="search-bar" id="search-bar">
                <span class="material-icons-round search-icon">search</span>
                <input type="text" id="search-input" placeholder="搜索文章、标签..." autocomplete="off">
                <div class="search-results" id="search-results"></div>
            </div>
        </div>
        <div class="nav-right" style="gap: 12px; align-items: center;">
            <a href="/editor" class="nav-create-btn" id="nav-create-btn" title="发布新文章" data-astro-reload>
                <span class="material-icons-round" style="font-size: 15px;">add</span>
                创作
            </a>
            <button class="nav-exit-dev-btn" id="nav-exit-dev-btn" title="退出开发者模式">
                退出
            </button>
            <button class="theme-toggle" id="theme-toggle" title="切换主题">
                <span class="material-icons-round" id="theme-icon">dark_mode</span>
            </button>
            <a href="/#about" class="nav-avatar-link">
                <!-- Using the downloaded avatar image -->
                <img src="/avatar.jpg" alt="OKay" class="nav-avatar">
            </a>
        </div>
    </div>
</nav>

<style>
    .nav-create-btn {
        display: none; /* hidden by default */
        align-items: center;
        gap: 4px;
        background: var(--accent);
        color: #fff;
        padding: 5px 12px;
        border-radius: 16px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s, transform 0.1s;
        box-shadow: 0 2px 6px rgba(0, 122, 204, 0.3);
        white-space: nowrap;
    }
    .nav-create-btn:hover {
        background: #0098ff;
        transform: translateY(-1px);
    }
    .nav-exit-dev-btn {
        display: none; /* hidden by default */
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-secondary);
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
        white-space: nowrap;
    }
    .nav-exit-dev-btn:hover {
        background: var(--surface);
        color: var(--text);
    }
</style>

<script>
    const setupHeader = () => {
        const themeToggle = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');
        const createBtn = document.getElementById('nav-create-btn');
        const exitDevBtn = document.getElementById('nav-exit-dev-btn');
        
        const updateIcon = (theme: string) => {
            if(themeIcon) {
                themeIcon.textContent = theme === 'dark' ? 'light_mode' : 'dark_mode';
            }
        };
        
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        updateIcon(currentTheme);

        if (themeToggle) {
            // Remove previous event listener to avoid duplicates in Astro view transitions
            const newBtn = themeToggle.cloneNode(true);
            themeToggle.parentNode?.replaceChild(newBtn, themeToggle);
            
            newBtn.addEventListener('click', () => {
                const current = document.documentElement.getAttribute('data-theme');
                const next = current === 'dark' ? 'light' : 'dark';
                
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('theme', next);
                
                const newIcon = newBtn.querySelector('#theme-icon');
                if(newIcon) {
                    newIcon.textContent = next === 'dark' ? 'light_mode' : 'dark_mode';
                }
            });
        }

        // Dev Mode UI Logic - only works on localhost (editor is dev-only)
        const isLocalDev = ['localhost', '127.0.0.1'].includes(window.location.hostname);
        const checkDevMode = () => {
            const isDev = localStorage.getItem('okay_dev_mode') === 'true' && isLocalDev;
            if (isDev) {
                if(createBtn) createBtn.style.display = 'flex';
                if(exitDevBtn) exitDevBtn.style.display = 'block';
            } else {
                if(createBtn) createBtn.style.display = 'none';
                if(exitDevBtn) exitDevBtn.style.display = 'none';
            }
        };

        checkDevMode();
        window.addEventListener('dev-mode-changed', checkDevMode);

        if (exitDevBtn) {
            exitDevBtn.addEventListener('click', () => {
                localStorage.removeItem('okay_dev_mode');
                document.body.classList.remove('dev-mode-active');
                checkDevMode();
                window.dispatchEvent(new Event('dev-mode-changed')); // Notify others
            });
        }
    };

    setupHeader();
    document.addEventListener('astro:page-load', setupHeader);
</script>
