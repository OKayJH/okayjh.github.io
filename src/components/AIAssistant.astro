---
const apiUrl = import.meta.env.PUBLIC_AI_GATEWAY_URL ?? '';
const enabled =
  Boolean(apiUrl) && import.meta.env.PUBLIC_AI_ASSISTANT_ENABLED !== 'false';
const assistantName = import.meta.env.PUBLIC_AI_ASSISTANT_NAME ?? '\u5c0fO';
const titleText = `${assistantName} \u52a9\u624b`;
const subtitleText = 'OKay\u7684\u667a\u80fd\u52a9\u624b';
const clearText = '\u6e05\u7a7a\u5bf9\u8bdd';
const closeText = '\u5173\u95ed';
const welcomeText = `\u4f60\u597d\uff0c\u6211\u662f${assistantName}\u3002\u6709\u4ec0\u4e48\u53ef\u4ee5\u5e2e\u5230\u4f60\uff1f`;
const statusReadyText = '\u5c31\u7eea';
const inputPlaceholder = `\u7ed9 ${assistantName} \u53d1\u9001\u6d88\u606f`;
const stopText = '\u505c\u6b62';
const sendText = '\u53d1\u9001';
---

{enabled && (
  <div class="ai-assistant-root" data-assistant-name={assistantName} data-api-url={apiUrl}>
    <button
      id="ai-toggle-btn"
      class="ai-toggle-btn"
      type="button"
      aria-controls="ai-panel"
      aria-expanded="false"
      title={titleText}
    >
      <span class="material-icons-round">smart_toy</span>
      <span class="ai-toggle-label">{assistantName}</span>
    </button>

    <section id="ai-panel" class="ai-panel hidden" aria-live="polite">
      <header class="ai-panel-header">
        <div class="ai-panel-title-wrap">
          <strong class="ai-panel-title">{assistantName}</strong>
          <span class="ai-panel-subtitle">{subtitleText}</span>
        </div>
        <div class="ai-panel-actions">
          <button id="ai-clear-btn" class="ai-icon-btn" type="button" title={clearText}>
            <span class="material-icons-round">delete_sweep</span>
          </button>
          <button id="ai-close-btn" class="ai-icon-btn" type="button" title={closeText}>
            <span class="material-icons-round">close</span>
          </button>
        </div>
      </header>

      <div id="ai-messages" class="ai-messages">
        <div class="ai-msg ai-msg-assistant">
          <p>{welcomeText}</p>
        </div>
      </div>

      <div class="ai-status-row">
        <span id="ai-status" class="ai-status">{statusReadyText}</span>
      </div>

      <form id="ai-form" class="ai-form">
        <textarea
          id="ai-input"
          class="ai-input"
          rows="3"
          placeholder={inputPlaceholder}
          maxlength="600"
        ></textarea>
        <div class="ai-form-actions">
          <button id="ai-stop-btn" class="ai-secondary-btn hidden" type="button">{stopText}</button>
          <button id="ai-send-btn" class="ai-send-btn" type="submit">{sendText}</button>
        </div>
      </form>
    </section>
  </div>
)}

<script is:inline>
  (() => {
    const root = document.querySelector('.ai-assistant-root');
    if (!root) return;
    if (root.getAttribute('data-mounted') === 'true') return;
    root.setAttribute('data-mounted', 'true');

    const assistantName = root.getAttribute('data-assistant-name') || '\u5c0fO';
    const endpoint = root.getAttribute('data-api-url') || '';

    const panel = document.getElementById('ai-panel');
    const toggleBtn = document.getElementById('ai-toggle-btn');
    const closeBtn = document.getElementById('ai-close-btn');
    const clearBtn = document.getElementById('ai-clear-btn');
    const form = document.getElementById('ai-form');
    const input = document.getElementById('ai-input');
    const sendBtn = document.getElementById('ai-send-btn');
    const stopBtn = document.getElementById('ai-stop-btn');
    const statusEl = document.getElementById('ai-status');
    const messagesWrap = document.getElementById('ai-messages');

    /** @type {{ role: 'user' | 'assistant'; content: string }[]} */
    const messages = [];
    let isSending = false;
    let activeController = null;

    const escapeHtml = (raw) =>
      raw
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const nowTime = () =>
      new Date().toLocaleTimeString('zh-CN', {
        hour: '2-digit',
        minute: '2-digit',
      });

    const setStatus = (text, kind = 'normal') => {
      if (!statusEl) return;
      statusEl.textContent = text;
      statusEl.classList.remove('is-error', 'is-busy');
      if (kind === 'error') statusEl.classList.add('is-error');
      if (kind === 'busy') statusEl.classList.add('is-busy');
    };

    const scrollToBottom = () => {
      if (!messagesWrap) return;
      messagesWrap.scrollTop = messagesWrap.scrollHeight;
    };

    const addMessage = (role, content) => {
      if (!messagesWrap) return null;
      const item = document.createElement('div');
      item.className = `ai-msg ${role === 'assistant' ? 'ai-msg-assistant' : 'ai-msg-user'}`;
      item.innerHTML = `<p>${escapeHtml(content).replace(/\n/g, '<br>')}</p><time>${nowTime()}</time>`;
      messagesWrap.appendChild(item);
      scrollToBottom();
      return item;
    };

    const updateMessage = (item, content) => {
      if (!item) return;
      const p = item.querySelector('p');
      if (p) {
        p.innerHTML = escapeHtml(content).replace(/\n/g, '<br>');
      }
      scrollToBottom();
    };

    const setPanelOpen = (open) => {
      if (!panel || !toggleBtn) return;
      panel.classList.toggle('hidden', !open);
      toggleBtn.setAttribute('aria-expanded', String(open));
      if (open && input) input.focus();
    };

    const setBusy = (busy) => {
      isSending = busy;
      if (sendBtn) sendBtn.disabled = busy;
      if (input) input.disabled = busy;
      if (stopBtn) stopBtn.classList.toggle('hidden', !busy);
    };

    const buildRequestMessages = () => {
      const history = messages.slice(-4);
      return history.map((m) => ({ role: m.role, content: m.content }));
    };

    const parseSseData = (raw) => {
      if (!raw) return '';
      if (raw === '[DONE]') return '__DONE__';

      try {
        const parsed = JSON.parse(raw);
        if (parsed?.error?.message) {
          throw new Error(parsed.error.message);
        }
        if (typeof parsed?.text === 'string') {
          return parsed.text;
        }
        if (typeof parsed?.delta === 'string') {
          return parsed.delta;
        }
        const maybe = parsed?.choices?.[0]?.delta?.content;
        if (typeof maybe === 'string') {
          return maybe;
        }
        return '';
      } catch {
        return raw;
      }
    };

    const readSseStream = async (stream, onDelta) => {
      const reader = stream.getReader();
      const decoder = new TextDecoder('utf-8');
      let buffer = '';

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });

        let splitIndex = buffer.indexOf('\n\n');
        while (splitIndex !== -1) {
          const rawEvent = buffer.slice(0, splitIndex).trim();
          buffer = buffer.slice(splitIndex + 2);

          if (rawEvent) {
            const lines = rawEvent.split('\n');
            const data = lines
              .filter((line) => line.startsWith('data:'))
              .map((line) => line.slice(5).trim())
              .join('\n');

            if (data) {
              const parsed = parseSseData(data);
              if (parsed === '__DONE__') return;
              if (parsed) onDelta(parsed);
            }
          }

          splitIndex = buffer.indexOf('\n\n');
        }
      }
    };

    const sendMessage = async (text) => {
      if (!endpoint) {
        setStatus('\u672a\u914d\u7f6e AI \u7f51\u5173\u5730\u5740\uff0c\u8bf7\u8054\u7cfb\u7ad9\u957f\u3002', 'error');
        return;
      }

      const userText = text.trim();
      if (!userText) return;

      setBusy(true);
      setStatus('\u601d\u8003\u4e2d...', 'busy');
      addMessage('user', userText);
      messages.push({ role: 'user', content: userText });
      input.value = '';

      const assistantItem = addMessage('assistant', '');
      let assistantText = '';
      activeController = new AbortController();

      try {
        const payload = {
          assistant: assistantName,
          messages: buildRequestMessages(),
          page: {
            title: document.title,
            path: window.location.pathname,
            url: window.location.href,
          },
        };

        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          signal: activeController.signal,
        });

        if (!response.ok) {
          const textResp = await response.text();
          throw new Error(textResp || `\u8bf7\u6c42\u5931\u8d25\uff08${response.status}\uff09`);
        }

        const contentType = response.headers.get('content-type') || '';
        if (contentType.includes('text/event-stream') && response.body) {
          await readSseStream(response.body, (delta) => {
            assistantText += delta;
            updateMessage(assistantItem, assistantText);
          });
        } else {
          const data = await response.json();
          assistantText =
            data?.answer ||
            data?.text ||
            data?.choices?.[0]?.message?.content ||
            '\u8fd9\u6b21\u6ca1\u6709\u8fd4\u56de\u53ef\u7528\u5185\u5bb9\u3002';
          updateMessage(assistantItem, assistantText);
        }

        const finalText = assistantText.trim() || '\u8fd9\u6b21\u6ca1\u6709\u751f\u6210\u6709\u6548\u56de\u590d\u3002';
        updateMessage(assistantItem, finalText);
        messages.push({ role: 'assistant', content: finalText });
        setStatus('\u5c31\u7eea');
      } catch (error) {
        const message =
          error?.name === 'AbortError'
            ? '\u5df2\u505c\u6b62\u751f\u6210\u3002'
            : `\u8bf7\u6c42\u5931\u8d25\uff1a${error?.message || '\u672a\u77e5\u9519\u8bef'}`;
        updateMessage(assistantItem, message);
        messages.push({ role: 'assistant', content: message });
        setStatus(message, 'error');
      } finally {
        activeController = null;
        setBusy(false);
      }
    };

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = panel ? !panel.classList.contains('hidden') : false;
        setPanelOpen(!isOpen);
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', () => setPanelOpen(false));
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        messages.length = 0;
        if (messagesWrap) messagesWrap.innerHTML = '';
        addMessage('assistant', `\u4e0a\u4e0b\u6587\u5df2\u6e05\u7a7a\u3002\u4f60\u53ef\u4ee5\u7ee7\u7eed\u5411 ${assistantName} \u63d0\u95ee\u3002`);
        setStatus('\u5bf9\u8bdd\u5df2\u6e05\u7a7a');
      });
    }

    if (stopBtn) {
      stopBtn.addEventListener('click', () => {
        if (activeController) activeController.abort();
      });
    }

    if (input) {
      input.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && !event.shiftKey) {
          event.preventDefault();
          if (!isSending) sendMessage(input.value);
        }
      });
    }

    if (form) {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        if (!isSending) sendMessage(input.value);
      });
    }
  })();
</script>

<style>
  .ai-assistant-root {
    position: fixed;
    right: 20px;
    bottom: 84px;
    z-index: 5500;
  }

  .ai-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent), #2f9bff);
    color: #fff;
    padding: 10px 16px;
    font-size: 0.9rem;
    font-weight: 700;
    box-shadow: var(--shadow-lg);
    cursor: pointer;
  }

  .ai-toggle-btn:hover {
    filter: brightness(1.03);
  }

  .ai-toggle-btn .material-icons-round {
    font-size: 18px;
  }

  .ai-panel {
    width: min(380px, calc(100vw - 24px));
    height: min(560px, calc(100vh - 160px));
    margin-bottom: 12px;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: var(--shadow-xl);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ai-panel.hidden {
    display: none;
  }

  .ai-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-bottom: 1px solid var(--border-light);
    background: var(--bg-secondary);
  }

  .ai-panel-title-wrap {
    display: flex;
    flex-direction: column;
  }

  .ai-panel-title {
    font-size: 0.98rem;
    color: var(--text);
  }

  .ai-panel-subtitle {
    font-size: 0.76rem;
    color: var(--text-muted);
  }

  .ai-panel-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-icon-btn {
    width: 30px;
    height: 30px;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-btn:hover {
    background: var(--bg-secondary);
    color: var(--text);
  }

  .ai-icon-btn .material-icons-round {
    font-size: 18px;
  }

  .ai-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px;
    background: linear-gradient(180deg, var(--surface), var(--bg-secondary));
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-msg {
    max-width: 88%;
    padding: 10px 12px;
    border-radius: 12px;
    font-size: 0.9rem;
    line-height: 1.55;
    border: 1px solid transparent;
    white-space: normal;
    word-break: break-word;
  }

  .ai-msg p {
    margin: 0;
  }

  .ai-msg time {
    display: block;
    margin-top: 6px;
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: right;
  }

  .ai-msg-assistant {
    align-self: flex-start;
    background: var(--bg);
    border-color: var(--border-light);
    color: var(--text);
  }

  .ai-msg-user {
    align-self: flex-end;
    background: var(--accent-light);
    border-color: rgba(26, 115, 232, 0.22);
    color: var(--text);
  }

  .ai-status-row {
    padding: 8px 14px;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    background: var(--bg-secondary);
  }

  .ai-status {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .ai-status.is-error {
    color: var(--red);
  }

  .ai-status.is-busy {
    color: var(--accent);
  }

  .ai-form {
    padding: 10px 12px 12px;
    background: var(--surface);
  }

  .ai-input {
    width: 100%;
    resize: none;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px;
    font-size: 0.9rem;
    font-family: inherit;
    line-height: 1.5;
    color: var(--text);
    background: var(--bg);
    outline: none;
  }

  .ai-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-light);
  }

  .ai-form-actions {
    margin-top: 8px;
    display: flex;
    justify-content: flex-end;
    gap: 8px;
  }

  .ai-secondary-btn,
  .ai-send-btn {
    border: none;
    border-radius: 10px;
    padding: 8px 12px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
  }

  .ai-secondary-btn {
    background: var(--bg-secondary);
    color: var(--text-secondary);
    border: 1px solid var(--border-light);
  }

  .ai-send-btn {
    background: var(--accent);
    color: #fff;
  }

  .ai-send-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .hidden {
    display: none !important;
  }

  @media (max-width: 768px) {
    .ai-assistant-root {
      right: 12px;
      bottom: 78px;
    }

    .ai-toggle-label {
      display: none;
    }

    .ai-toggle-btn {
      width: 48px;
      height: 48px;
      padding: 0;
      justify-content: center;
      border-radius: 50%;
    }

    .ai-panel {
      width: calc(100vw - 24px);
      height: min(70vh, 560px);
    }
  }
</style>
